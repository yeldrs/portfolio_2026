---
import "../styles/global.css";

// Fichier : src/layouts/BaseLayout.astro
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string; // relative path used for og:image / twitter:image
  structuredData?: Record<string, unknown>; // extra JSON-LD injected in <head>
}

const {
  title,
  description = "Yassine El Idrissi UX Product design official website portfolio.",
  image = "/images/profile-pic.webp",
  structuredData,
} = Astro.props;

// Absolute URLs for SEO / social / structured data (Astro.site = https://yassineelidrissi.com)
const site = Astro.site ?? new URL("https://yassineelidrissi.com");
// build.format:'file' exposes paths as /about.html — strip the extension so the
// canonical/OG URL is always the clean, extensionless form GitHub Pages serves.
const cleanPath = Astro.url.pathname
  .replace(/\/index\.html$/, "/")
  .replace(/\.html$/, "");
const canonicalURL =
  new URL(cleanPath || "/", site).href.replace(/(.)\/$/, "$1");
const ogImage = new URL(image, site).href;

// Site-wide identity for search engines and AI agents
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Yassine El Idrissi",
  url: site.href,
  jobTitle: "UX Product Designer",
  sameAs: ["https://www.linkedin.com/in/yassineelidrissi/"],
  image: new URL("/images/profile-pic.webp", site).href,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (link previews on social + read by some AI crawlers) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Yassine El Idrissi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Self-hosted fonts (see @font-face in global.css). No Google Fonts dependency. -->
    <link rel="preload" href="/fonts/manrope-latin-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/lora-italic-latin-var.woff2" as="font" type="font/woff2" crossorigin />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="52b0a573-2288-46c1-9e4f-a27cdae08238"></script>
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"
    ></script>
    {
      /*<script async src="https://t.contentsquare.net/uxa/1027ad213768f.js"
    ></script>*/
    }

    <script is:inline>
      (function (h, o, t, j, a, r) {
        h.hj =
          h.hj ||
          function () {
            (h.hj.q = h.hj.q || []).push(arguments);
          };
        h._hjSettings = { hjid: 3866151, hjsv: 6 };
        a = o.getElementsByTagName("head")[0];
        r = o.createElement("script");
        r.async = 1;
        r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
        a.appendChild(r);
      })(window, document, "https://static.hotjar.com/c/hotjar-", ".js?sv=");
    </script>

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/android-chrome-16x16.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/android-chrome-32x32.png"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#4364e8" />

    <!-- Structured data: site-wide identity + optional per-page schema -->
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <style is:global>
      html,
      body {
        margin: 0;
        padding: 0;
        overflow-y: auto;
        overflow-x: hidden;
      }
    </style>
  </head>

 <body
    class="bg-background-page text-text-body-primary min-h-screen flex flex-col font-sans"
  >
    <header
      class="fixed inset-x-0 top-0 z-50 bg-background-primary border-b border-gray-200"
    >
      <Navbar />
    </header>

    <main class="flex-1 pt-4xl md:pt-3xl">
      <slot />
    </main>

    <Footer />
  </body>
</html>
