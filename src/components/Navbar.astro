---
import Container from "./Container.astro";

// Définition des liens de navigation
const navLinks = [
  { name: "Work", href: "/#projects" },
  { name: "About", href: "/about" },
  { name: "Contact", href: "/#contact" },
];

const currentPath = Astro.url.pathname;

// Détermine si un lien doit être actif dans la barre de navigation.
function isActive(
  link: { name: string; href: string },
  current: string,
): boolean {
  if (link.name === "Contact") {
    return false;
  }

  const linkPath = link.href.split("#")[0] || "/";

  if (linkPath === "/") {
    return current === "/" || current.endsWith("/index.html");
  }

  return current === linkPath || current.startsWith(linkPath + "/");
}
---

<nav
  id="main-navbar"
  class:list={[
    "py-md",
    "sticky top-0",
    "z-[60]",
    "bg-background-primary/95 backdrop-blur-sm",
  ]}
  role="navigation"
  aria-label="Main navigation"
>
  <Container class="flex justify-between items-center">
    <a
      href="/"
      data-sa-event="nav_click_home"
      class="text-base normal text-text-body-primary hover:text-text-body-secondary transition duration-150 uppercase"
      aria-label="Yassine El Idrissi - Retour à l'accueil"
    >
      Yassine El Idrissi
    </a>

    <div class="hidden md:flex space-x-lg" role="menu">
      {
        navLinks.map((link) => {
          const isLinkActive = isActive(link, currentPath);
          const eventName = `nav_click_${link.name.toLowerCase().replace(/\s+/g, "_")}`;

          return (
            <a
              href={link.href}
              data-sa-event={eventName}
              class:list={[
                "text-base",
                "text-text-body-primary",
                "hover:text-text-body-secondary",
                "transition duration-150",
                "uppercase",
                isLinkActive ? "font-extrabold" : "font-normal",
              ]}
              aria-current={isLinkActive ? "page" : undefined}
              role="menuitem"
            >
              {link.name}
            </a>
          );
        })
      }
    </div>

    <button
      id="mobile-menu-button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden text-text-body-primary relative h-10 w-10 flex items-center justify-center p-0"
    >
      <div id="burger-icon" class="w-6 h-6 absolute">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </div>
      <div id="close-icon" class="hidden w-6 h-6 absolute">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </div>
    </button>
  </Container>
</nav>

<div
  id="mobile-menu"
  class="md:hidden fixed top-[72px] left-0 right-0 bottom-0 z-50 bg-background-primary/95 backdrop-blur-sm
            transition-opacity duration-300 ease-in-out opacity-0 invisible overflow-y-auto"
  aria-hidden="true"
  role="dialog"
>
  <Container class="flex flex-col space-y-lg pt-lg pb-xl">
    <div role="menu" class="flex"></div></Container
  >
</div>
