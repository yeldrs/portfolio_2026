---
import Container from "./Container.astro";

const navLinks = [
  { name: "Work", href: "/#projects" },
  { name: "About", href: "/about" },
  { name: "Contact", href: "/#contact" },
];

const currentPath = Astro.url.pathname;

function getInitialActive(name: string, path: string) {
  if (name === "About" && path.includes("/about")) return true;
  return false;
}
---

<nav
  id="main-navbar"
  class="py-md sticky top-0 z-[60] bg-background-primary/95 backdrop-blur-sm"
>
  <Container class="flex justify-between items-center">
    <a
      href="/"
      id="nav-logo"
      data-umami-event="nav-logo-click"
      class:list={[
        "text-base transition duration-150 uppercase",
        currentPath === "/" ? "font-extrabold" : "font-normal",
      ]}
    >
      Yassine El Idrissi
    </a>

    <div class="hidden md:flex space-x-lg" role="menu">
      {
        navLinks.map((link) => {
          const isActive = getInitialActive(link.name, currentPath);
          return (
            <a
              href={link.href}
              id={`nav-link-${link.name.toLowerCase().replace(/\s+/g, "")}`}
              data-umami-event="nav-link-click"
              data-umami-event-name={link.name}
              class:list={[
                "nav-item text-base uppercase transition duration-150",
                isActive
                  ? "font-extrabold text-text-body-primary"
                  : "font-normal text-text-body-primary",
              ]}
            >
              {link.name}
            </a>
          );
        })
      }
    </div>

    <button
      id="mobile-menu-button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-umami-event="mobile-menu-toggle"
      class="md:hidden text-text-body-primary relative h-10 w-10 flex items-center justify-center p-0"
    >
      <div id="burger-icon" class="w-6 h-6 absolute">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </div>
      <div id="close-icon" class="hidden w-6 h-6 absolute">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </div>
    </button>
  </Container>
</nav>

<div
  id="mobile-menu"
  class="md:hidden fixed top-[72px] left-0 right-0 bottom-0 z-50 bg-background-primary/95 backdrop-blur-sm transition-opacity duration-300 ease-in-out opacity-0 invisible overflow-y-auto"
  aria-hidden="true"
  role="dialog"
>
  <Container class="flex flex-col space-y-lg pt-lg pb-xl">
    <div role="menu" class="flex flex-col space-y-lg">
      {
        navLinks.map((link) => {
          const isActive = getInitialActive(link.name, currentPath);
          return (
            <a
              href={link.href}
              data-umami-event="mobile-nav-click"
              data-umami-event-name={link.name}
              class:list={[
                "text-base uppercase transition duration-150",
                isActive
                  ? "font-extrabold text-text-body-primary"
                  : "font-normal text-text-body-primary",
              ]}
            >
              {link.name}
            </a>
          );
        })
      }
    </div>
  </Container>
</div>

<script>
  function setupNavObserver() {
    const logo = document.getElementById("nav-logo");
    const workLink = document.getElementById("nav-link-work");
    const projectsSection = document.getElementById("projects");
    const currentPath = window.location.pathname;

    if (
      !projectsSection ||
      (currentPath !== "/" && currentPath !== "/index.html")
    ) {
      return;
    }

    if (!workLink || !logo) {
      return;
    }

    const observerOptions = {
      root: null,
      rootMargin: "-50% 0px -50% 0px",
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          workLink.classList.add("font-extrabold");
          workLink.classList.remove("font-normal");
          logo.classList.add("font-normal");
          logo.classList.remove("font-extrabold");
        } else {
          if (window.scrollY < 100) {
            workLink.classList.remove("font-extrabold");
            workLink.classList.add("font-normal");
            logo.classList.add("font-extrabold");
            logo.classList.remove("font-normal");
          }
        }
      });
    }, observerOptions);

    observer.observe(projectsSection);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupNavObserver);
  } else {
    setupNavObserver();
  }

  document.addEventListener("astro:after-swap", setupNavObserver);

  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const burgerIcon = document.getElementById("burger-icon");
  const closeIcon = document.getElementById("close-icon");

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener("click", () => {
      const isOpen = mobileMenu.classList.contains("opacity-100");

      if (isOpen) {
        mobileMenu.classList.remove("opacity-100", "visible");
        mobileMenu.classList.add("opacity-0", "invisible");
        burgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        mobileMenuButton.setAttribute("aria-expanded", "false");
      } else {
        mobileMenu.classList.remove("opacity-0", "invisible");
        mobileMenu.classList.add("opacity-100", "visible");
        burgerIcon?.classList.add("hidden");
        closeIcon?.classList.remove("hidden");
        mobileMenuButton.setAttribute("aria-expanded", "true");
      }
    });

    const mobileMenuLinks = mobileMenu.querySelectorAll("a");
    mobileMenuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.remove("opacity-100", "visible");
        mobileMenu.classList.add("opacity-0", "invisible");
        burgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        mobileMenuButton.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>

<style>
  .nav-item,
  #nav-logo {
    transition: font-weight 0.2s ease;
    will-change: font-weight;
  }
</style>
