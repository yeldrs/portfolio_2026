---
import Button from "./Button.astro";

export interface Props {
  headline: string;
  client: string;
  description?: string;
  role: string;
  projectLink: string;
  imageAlt: string;
  imageUrl: string;
  direction?: "default" | "reverse";
  id?: string;
}

const {
  headline,
  client,
  description,
  role,
  projectLink,
  imageAlt,
  imageUrl,
  direction = "default",
  id,
} = Astro.props;

// --- LOGIQUE DE TRACKING MUTUALISÉE ---

// Format pour Simple Analytics (snake_case : view_project_900_care)
const projectSlugSA = client
  .toLowerCase()
  .replace(/\s+/g, "_")
  .replace(/[^\w_]/g, "");
const eventNameSA = `view_project_${projectSlugSA}`;

// Format pour Umami (kebab-case : 900-care)
const projectSlugUmami = client
  .toLowerCase()
  .replace(/\s+/g, "-")
  .replace(/[^\w-]/g, "");

const directionClass = direction === "reverse" ? "md:flex-row-reverse" : "";
---

<article
  id={id ?? undefined}
  role="article"
  aria-label={headline}
  class={`flex flex-col md:flex-row gap-xl md:gap-3xl ${directionClass} md:items-start`}
>
  <h1
    class="h-display md:hidden m-0"
    set:html={headline}
  />

  <a
    href={projectLink}
    data-sa-event={eventNameSA}
    data-umami-event="project-image-click"
    data-umami-event-project={projectSlugUmami}
    aria-label={`Voir le projet : ${headline}`}
    class="block group flex-1 md:basis-1/2 relative rounded-2xl aspect-[4/3] order-2 md:order-none overflow-hidden"
  >
    <img
      src={imageUrl}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover block rounded-2xl transition-transform duration-500 group-hover:scale-90"
      loading="lazy"
    />
  </a>

  <section class="flex-1 md:basis-1/2 order-3 md:order-none space-y-lg">
    <h1
       class="h-display hidden md:block m-0"
      set:html={headline}
    />
    <div class="space-y-lg">
      <div>
        <span class="block text-base font-normal text-text-body-tertiary mb-xxs"
          >Client</span
        >
        <p class="text-base font-normal text-text-body-primary">
          {client}
        </p>
      </div>

      <div>
        <span class="block text-base font-normal text-text-body-tertiary mb-xxs"
          >Description</span
        >
        <p class="text-base font-normal text-text-body-primary leading-normal">
          {description}
        </p>
      </div>

      <div>
        <span class="block text-base font-normal text-text-body-tertiary mb-xxs"
          >Role</span
        >
        <p class="text-base font-normal text-text-body-primary">
          {role}
        </p>
      </div>
    </div>
    <div>
      <Button
        href={projectLink}
        data-sa-event={eventNameSA}
        data-umami-event="project-button-click"
        data-umami-event-project={projectSlugUmami}
      >
        View project
      </Button>
    </div>
  </section>
</article>
