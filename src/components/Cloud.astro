---
import { tokens } from "../styles/tokens.js";
// src/components/Cloud.astro
// Nuage décoratif atomique et paramétrable.
// Forme via `variant`, couleur via token accent-deco (`shade`) ou `color` libre,
// taille/position/rotation/opacité/flou par props. Purement décoratif (aria-hidden).

export interface Props {
  variant?: "large" | "medium" | "small";
  shade?: 50 | 100 | 200 | 300 | 400 | 500 | 600; // niveau accent-deco
  color?: string;                                   // hex libre, prioritaire sur shade
  width?: string;                                   // ex: "640px", "40vw"
  blur?: "none" | "sm" | "md" | "lg" | "xl" | "2xl" | "3xl";
  opacity?: number;                                 // 0 to 1
  rotate?: number;                                  // degrés
  top?: string;
  right?: string;
  bottom?: string;
  left?: string;
  mobile?: {
    opacity?: number;
    top?: string;
    right?: string;
    bottom?: string;
    left?: string;
  };
  class?: string;
}

const {
  variant = "medium",
  shade = 300,
  color,
  width = "360px",
  blur = "md",
  opacity = 0.6,
  rotate = 0,
  top,
  right,
  bottom,
  left,
  mobile,
  class: className = "",
} = Astro.props;

const paths = {
  large: {
    viewBox: "0 0 850.5 356.3",
    d: "m788.8,208.4c-2.6-38.1-48.4-68.5-104.5-68.5s-4.1,0-6.1.1c-14.4-40-52.6-68.6-97.6-68.6s-11.1.5-16.4,1.3C536.2,29.4,482.1,0,419.9,0s-119.9,31.4-146.9,77.1c-8.4-2.1-17.3-3.2-26.3-3.2-56.5,0-102.9,42.7-109,97.6-18.6,3.2-35.3,10.5-48.2,20.7-4.4-.5-8.8-.8-13.4-.8C34.1,191.4,0,214.2,0,242.3s34.1,50.9,76.1,50.9,5,0,7.4-.2c17.8,16.9,44.8,27.7,75,27.7s26.4-2.2,38.2-6.1c21.6,25.1,60.7,41.8,105.5,41.8s86.5-17.9,107.5-44.3c13.1,6.4,28.6,10.2,45.2,10.2,23.7,0,45.2-7.6,60.4-19.8,21.2,12.2,51,19.8,84,19.8s75.1-11.1,96.1-28c16.4,9.4,39.2,15.3,64.3,15.3,50.1,0,90.8-23.2,90.8-51.9s-25.9-42.3-61.8-49.2Z",
  },
  medium: {
    viewBox: "0 0 849.1 313.6",
    d: "m748.7,143.5c-12.8,0-25.1,1.5-36.5,4.1-10-19.7-37.4-34.1-70.2-35.4,2.7-40.9-66.4-72.5-139.2-70.3-46.6-69.2-218.1-49.9-219,38.4-67.5,9.2-119.1,36.3-130.4,69.9-146.8-26.7-237.3,94.7-39.9,107.4,18.7,20.6,70.3,26.9,99.7,14.9,16.9,46.7,184.9,52.6,233,23,32,22.9,104.9,20.6,132.2-5.8,53.1,17,153.7,7.7,186.4-23.8,123.8-12.6,104.9-123.3-16.2-122.3Z",
  },
  small: {
    viewBox: "0 0 849.1 374.1",
    d: "m718.9,113.7c-12.5,0-24.6,1.4-36.1,4-24.5-33.2-70.5-55.5-123.2-55.5s-23.3,1.1-34.2,3.2C502,26.8,451.5,0,393,0s-133.2,41.4-144.4,95.6c-69.9,6.2-125.7,32.7-141.9,66.8C46.1,168.6,0,200.4,0,238.8s57.5,77.5,128.4,77.5,26.3-1.2,38.4-3.5c15.4,35.6,60.3,61.4,113.3,61.4s80-16.7,101.1-41.9c32.2,20.9,73.7,33.5,119,33.5s120.1-25,153.6-63.1c19.2,8.6,41.4,13.6,65.1,13.6,71.9,0,130.2-45.3,130.2-101.3s-58.3-101.3-130.2-101.3Z",
  },
};

const blurClass = {
  none: "",
  sm: "blur-sm",
  md: "blur-md",
  lg: "blur-lg",
  xl: "blur-xl",
  "2xl": "blur-2xl",
  "3xl": "blur-3xl",
}[blur];

const fill = color ?? tokens.primitives.color["accent-deco"][shade];
const shape = paths[variant] ?? paths.medium;

const positionStyle = [
  `width:${width}`,
  `opacity:${opacity}`,
  `color:${fill}`,
  rotate ? `transform:rotate(${rotate}deg)` : "",
  top !== undefined ? `top:${top}` : "",
  right !== undefined ? `right:${right}` : "",
  bottom !== undefined ? `bottom:${bottom}` : "",
  left !== undefined ? `left:${left}` : "",
]
  .filter(Boolean)
  .join(";");

const mobilePositionStyle = [
  `width:${width}`,
  `opacity:${mobile?.opacity ?? opacity}`,
  `color:${fill}`,
  rotate ? `transform:rotate(${rotate}deg)` : "",
  mobile?.top !== undefined ? `top:${mobile.top}` : top !== undefined ? `top:${top}` : "",
  mobile?.right !== undefined ? `right:${mobile.right}` : right !== undefined ? `right:${right}` : "",
  mobile?.bottom !== undefined ? `bottom:${mobile.bottom}` : bottom !== undefined ? `bottom:${bottom}` : "",
  mobile?.left !== undefined ? `left:${mobile.left}` : left !== undefined ? `left:${left}` : "",
]
  .filter(Boolean)
  .join(";");
---

<svg
  class={`pointer-events-none absolute -z-10 hidden h-auto md:block ${blurClass} ${className}`}
  style={positionStyle}
  viewBox={shape.viewBox}
  fill="currentColor"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d={shape.d} />
</svg>

<svg
  class={`pointer-events-none absolute -z-10 block h-auto md:hidden ${blurClass} ${className}`}
  style={mobilePositionStyle}
  viewBox={shape.viewBox}
  fill="currentColor"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d={shape.d} />
</svg>