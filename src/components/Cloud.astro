---
import { tokens } from "../styles/tokens.js";
// src/components/Cloud.astro
// Nuage décoratif atomique et paramétrable.
// Forme via `variant`, couleur via token accent-deco (`shade`) ou `color` libre,
// taille/position/rotation/opacité/flou par props. Purement décoratif (aria-hidden).

export interface Props {
  variant?: "wide" | "medium" | "small";
  shade?: 50 | 100 | 200 | 300 | 400 | 500 | 600; // niveau accent-deco
  color?: string;                                   // hex libre, prioritaire sur shade
  width?: string;                                   // ex: "640px", "40vw"
  blur?: "none" | "sm" | "md" | "lg" | "xl" | "2xl" | "3xl";
  opacity?: number;                                 // 0 to 1
  rotate?: number;                                  // degrés
  top?: string;
  right?: string;
  bottom?: string;
  left?: string;
  class?: string;
}

const {
  variant = "medium",
  shade = 300,
  color,
  width = "360px",
  blur = "md",
  opacity = 0.6,
  rotate = 0,
  top,
  right,
  bottom,
  left,
  class: className = "",
} = Astro.props;

const paths = {
  wide: {
    viewBox: "0 0 1079.3 322.4",
    d: "m167.9,228.8c-2.9,0-5.8.3-8.4.9-5.7-7.7-16.5-13-28.8-13s-5.4.3-8,.8c-5.5-9-17.2-15.3-30.9-15.3s-31.1,9.7-33.7,22.3c-16.3,1.4-29.3,7.6-33.1,15.6-14.1,1.5-24.9,8.9-24.9,17.8s13.4,18.1,30,18.1,6.1-.3,9-.8c3.6,8.3,14.1,14.3,26.4,14.3s18.7-3.9,23.6-9.8c7.5,4.9,17.2,7.8,27.8,7.8s28.1-5.8,35.9-14.7c4.5,2,9.7,3.2,15.2,3.2,16.8,0,30.4-10.6,30.4-23.6s-13.6-23.6-30.4-23.6Z m491.1,62.8c-5.6,0-10.9.6-15.8,1.8-4.4-8.6-16.3-14.8-30.5-15.4,0-.3,0-.5,0-.8,0-16.5-26-29.8-58.1-29.8s-1.6,0-2.4,0c-8.6-11.1-25.3-18.6-44.5-18.6-27.7,0-50.3,15.8-50.7,35.3-29.3,4-51.8,15.8-56.7,30.4-5.2-.9-10.8-1.3-16.6-1.3-27.8,0-50.4,10.7-50.4,24s22.2,23.8,49.7,24c5.5,5.5,15.6,9.2,27.1,9.2s11.4-1,16.2-2.7c4.4,10.3,28,18.2,56.5,18.2s34.3-3.2,44.8-8.2c6.7,4.3,16.3,7,27,7s23.8-3.8,30.5-9.5c8.7,2.4,18.8,3.7,29.7,3.7,22.2,0,41.6-5.7,51.3-14.1,21.1-2,37.2-13.1,37.2-26.4s-19.8-26.8-44.3-26.8Z m1034.7,215.6c-1.9-27.5-34.9-49.4-75.4-49.4s-2.9,0-4.4,0c-10.4-28.9-38-49.5-70.4-49.5s-8,.3-11.8.9c-20.2-31.3-59.2-52.5-104.1-52.5s-86.5,22.6-106,55.6c-6.1-1.5-12.5-2.3-19-2.3-40.7,0-74.3,30.8-78.6,70.4-13.4,2.3-25.4,7.6-34.8,14.9-3.1-.4-6.4-.6-9.7-.6-30.3,0-54.9,16.4-54.9,36.7s24.6,36.7,54.9,36.7,3.6,0,5.4-.2c12.8,12.2,32.3,20,54.1,20s19.1-1.6,27.5-4.4c15.6,18.1,43.8,30.2,76.1,30.2s62.4-12.9,77.6-32c9.4,4.6,20.6,7.3,32.6,7.3,17.1,0,32.6-5.5,43.6-14.3,15.3,8.8,36.8,14.3,60.6,14.3s54.2-8,69.4-20.2c11.9,6.8,28.3,11,46.4,11,36.2,0,65.5-16.8,65.5-37.4s-18.7-30.5-44.6-35.5Z",
  },
  medium: {
    viewBox: "0 0 370 137.1",
    d: "m325.7,62.8c-5.6,0-10.9.6-15.8,1.8-4.4-8.6-16.3-14.8-30.5-15.4,0-.3,0-.5,0-.8,0-16.5-26-29.8-58.1-29.8s-1.6,0-2.4,0C210.2,7.5,193.5,0,174.4,0c-27.7,0-50.3,15.8-50.7,35.3-29.3,4-51.8,15.8-56.7,30.4-5.2-.9-10.8-1.3-16.6-1.3-27.8,0-50.4,10.7-50.4,24s22.2,23.8,49.7,24c5.5,5.5,15.6,9.2,27.1,9.2s11.4-1,16.2-2.7c4.4,10.3,28,18.2,56.5,18.2s34.3-3.2,44.8-8.2c6.7,4.3,16.3,7,27,7s23.8-3.8,30.5-9.5c8.7,2.4,18.8,3.7,29.7,3.7,22.2,0,41.6-5.7,51.3-14.1,21.1-2,37.2-13.1,37.2-26.4s-19.8-26.8-44.3-26.8Z",
  },
  small: {
    viewBox: "0 0 198.3 87.4",
    d: "m167.9,26.6c-2.9,0-5.8.3-8.4.9-5.7-7.7-16.5-13-28.8-13s-5.4.3-8,.8C117.2,6.2,105.4,0,91.8,0s-31.1,9.7-33.7,22.3c-16.3,1.4-29.3,7.6-33.1,15.6C10.8,39.4,0,46.8,0,55.8s13.4,18.1,30,18.1,6.1-.3,9-.8c3.6,8.3,14.1,14.3,26.4,14.3s18.7-3.9,23.6-9.8c7.5,4.9,17.2,7.8,27.8,7.8s28.1-5.8,35.9-14.7c4.5,2,9.7,3.2,15.2,3.2,16.8,0,30.4-10.6,30.4-23.6s-13.6-23.6-30.4-23.6Z",
  },
};

const blurClass = {
  none: "",
  sm: "blur-sm",
  md: "blur-md",
  lg: "blur-lg",
  xl: "blur-xl",
  "2xl": "blur-2xl",
  "3xl": "blur-3xl",
}[blur];

const fill = color ?? tokens.primitives.color["accent-deco"][shade];
const shape = paths[variant];

const positionStyle = [
  `width:${width}`,
  `opacity:${opacity}`,
  `color:${fill}`,
  rotate ? `transform:rotate(${rotate}deg)` : "",
  top !== undefined ? `top:${top}` : "",
  right !== undefined ? `right:${right}` : "",
  bottom !== undefined ? `bottom:${bottom}` : "",
  left !== undefined ? `left:${left}` : "",
]
  .filter(Boolean)
  .join(";");
---

<svg
  class={`pointer-events-none absolute -z-10 h-auto ${blurClass} ${className}`}
  style={positionStyle}
  viewBox={shape.viewBox}
  fill="currentColor"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d={shape.d} />
</svg>