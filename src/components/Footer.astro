---
import Container from "./Container.astro";
import CopyIcon from "./CopyIcon.astro";

interface SocialLink {
  name: string;
  href: string;
  icon: string;
}

const socialLinks: SocialLink[] = [
  {
    name: "LinkedIn",
    href: "#",
    icon: "M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z",
  },
];

const currentYear = new Date().getFullYear();
const emailAddress = "contact@yassineelidrissi.com";

// 🎯 Fonction de copie mise à jour pour positionner le toast par rapport au conteneur cliqué (e.currentTarget)
const copyToClipboard = `(function(e) {
const email = "${emailAddress}";
  // Utiliser currentTarget pour obtenir l'élément sur lequel l'événement est attaché
const clickedElement = e.currentTarget; 

// Vérification de la sécurité (inchangée)
if (window.isSecureContext === false && window.location.protocol !== 'http:') {
   console.error("navigator.clipboard est limité aux contextes sécurisés (HTTPS ou localhost).");
   alert("La copie dans le presse-papiers a échoué car le site n'est pas sécurisé.");
   return;
 }

navigator.clipboard.writeText(email).then(() => {

 // --- Code du Toast ---
 const message = "Email copied!";

 let existingToast = document.getElementById('copy-toast');
 if (existingToast) {
  existingToast.remove();
 }

 // Récupération des coordonnées et de la taille de l'élément cliqué
 const rect = clickedElement.getBoundingClientRect();
 
 const toast = document.createElement('div');
 toast.id = 'copy-toast';
 toast.textContent = message;

 // STYLES TAILWIND + POSITIONNEMENT DYNAMIQUE (fixed, centré sous l'élément cliqué)
 toast.style.cssText = \`
  position: fixed;
  /* Positionnement horizontal : centre de l'élément cliqué */
  left: \${rect.left + rect.width / 2}px;
  /* Positionnement vertical : juste en dessous de l'élément cliqué + un petit décalage (10px) */
  top: \${rect.bottom + 10}px; 
  
  /* Transformation pour centrer horizontalement et préparer l'animation (opacity 0) */
  transform: translateX(-50%); 
 
  /* Styles visuels */
  background-color: black;
  color: white;
  padding: 0.5rem 1rem;
  border-radius: 0.5rem;
  font-size: 0.875rem; /* text-sm */
  font-weight: 600;
  z-index: 50;
 
  /* Transitions initiales */
  opacity: 0;
  transition: opacity 0.3s, transform 0.3s;
 \`;

 document.body.appendChild(toast);

 // 2. Afficher le toast (légère translation verticale pour l'effet)
 setTimeout(() => {
  toast.style.opacity = '1';
  // Légère animation vers le haut (pas de changement Y car on a utilisé rect.bottom)
  toast.style.transform = 'translateX(-50%) translateY(0)'; 
 }, 10);

 // 3. Masquer et supprimer le toast après 2.5 secondes
 setTimeout(() => {
  toast.style.opacity = '0';
  toast.style.transform = 'translateX(-50%) translateY(-10px)'; // Animation vers le haut et disparition
  
  setTimeout(() => toast.remove(), 300);
 }, 2500);
 // --- Fin du code du Toast ---

}).catch(err => {
 console.error("Failed to copy email: ", err);
 alert("Impossible de copier l'e-mail. Veuillez le copier manuellement.");
});
}).call(this, event)`;
---

<footer
  id="contact"
  class="py-xl mt-7xl border-t border-stroke-secondary space-y-xl"
  aria-labelledby="footer-heading"
>
  <Container class="py-2xl">
    <div
      class="flex flex-col items-center justify-center text-center space-y-lg"
    >
      <p
        id="footer-heading"
        class="text-text-body-primary text-lg font-semibold"
      >
        Let's connect !
      </p>

      <p class="text-text-body-primary text-base font-normal">
        For any questions or collaboration requests.
      </p>

      <div
        class="flex items-center space-x-sm border border-stroke-neutral-primary rounded-xl px-md py-sm-d cursor-pointer transition hover:bg-gray-50/10"
        onclick={copyToClipboard}
        role="button"
        tabindex="0"
        aria-label={`Copy contact email address: ${emailAddress} to clipboard`}
      >
        <CopyIcon />
        <p class="text-text-body-primary text-md font-semibold">
          {emailAddress}
        </p>
      </div>
    </div>
  </Container>

  <div class="w-full border-b border-stroke-secondary"></div>

  <Container>
    <div
      class="flex flex-col md:flex-row justify-between items-center text-center md:text-left space-y-md md:space-y-0"
    >
      <small class="text-sm font-normal text-text-body-secondary">
        &copy; {currentYear} Yassine EL IDRISSI. All rights reserved.
      </small>

      <div class="flex space-x-lg">
        {
          socialLinks.map((link) => (
            // Ajout de rel="noopener noreferrer" pour la sécurité
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Visit my ${link.name} profile`}
              class="text-text-body-primary hover:text-gray-600 transition-colors"
            >
              <svg
                class="w-6 h-6 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                role="img"
                aria-hidden="true"
              >
                <path d={link.icon} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</footer>
