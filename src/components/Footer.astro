---
// Fichier : src/components/Footer.astro
import Container from './Container.astro';

// Définition des liens sociaux avec le PATH SVG correct pour LinkedIn (16x16)
const socialLinks = [
 { 
    name: 'LinkedIn', 
    href: '#', // Remplacez # par votre URL LinkedIn
    // PATH de l'icône LinkedIn (bi bi-linkedin 16x16)
    icon: 'M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z' 
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="mt-7xl border-t border-stroke-secondary">
  
  <Container>
    <div class="py-xl flex flex-col md:flex-row justify-between items-center text-center md:text-left space-y-md md:space-y-0">
      
      <p class="text-sm font-normal text-text-body-tertiary">
        &copy; {currentYear} Yassine EL IDRISSI. All rights reserved.
      </p>

      <div class="flex space-x-lg">
        {socialLinks.map((link) => (
          <a 
            href={link.href} 
            target="_blank" 
            aria-label={`Lien vers ${link.name}`} 
            class="text-text-body-primary hover:text-gray-600 transition-colors"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            {/* Ajustement: Si c'est LinkedIn, utiliser un groupe pour l'échelle si nécessaire,
                                 mais le simple <path> fonctionne si la viewBox est correctement gérée.
                                 Puisque le path est 16x16, il sera mis à l'échelle par la viewBox 24x24 et le W-6 H-6. */}
              <path d={link.icon} />
            </svg>
          </a>
        ))}
      </div>

    </div>
  </Container>
</footer>