---
// Fichier : src/components/Footer.astro
import Container from './Container.astro';

// Placeholder pour les liens sociaux
const socialLinks = [
  // J'utilise ici des icônes SVG simples (paths) comme placeholders
  { name: 'LinkedIn', href: '#', icon: 'M16 8a6 6 0 016 6v7H18v-7a3 3 0 00-3-3 3 3 0 00-3 3v7H8v-7a6 6 0 016-6zM4 10h4v14H4zM6 4a2 2 0 100 4 2 2 0 000-4z' },
  { name: 'Dribbble', href: '#', icon: 'M23 12.5a.5.5 0 00-.5-.5h-2.174a.5.5 0 00-.5.5v1a.5.5 0 00.5.5H23a.5.5 0 00.5-.5V12.5zM14 11v8.5a.5.5 0 00.5.5h1.5a.5.5 0 00.5-.5V11a.5.5 0 00-.5-.5H15a.5.5 0 00-.5.5z' }, // Icône simplifiée
  { name: 'Twitter/X', href: '#', icon: 'M23 3a10 10 0 01-3 1 5 5 0 00-4-2c-2.8 0-5 2.2-5 5 0 1 .4 2 1 3-4-.2-7-2.3-9-5a5 5 0 001 6c-1.5 0-3-.5-4-1v.5c0 3 2 5 5 6-1 .2-2 .3-3 .2s-2 0-3-.2c1 3 3 5 7 5a10 10 0 007-3 10 10 0 003-7v-.5a7 7 0 002-2.5z' }
];

const currentYear = new Date().getFullYear();
---

<footer class="mt-7xl border-t border-stroke-secondary">
    
    <Container>
        <div class="py-xl flex flex-col md:flex-row justify-between items-center text-center md:text-left space-y-md md:space-y-0">
            
            <p class="text-sm font-medium text-text-body-tertiary">
                &copy; {currentYear} [Votre Nom]. Tous droits réservés.
            </p>

            <div class="flex space-x-lg">
                {socialLinks.map((link) => (
                    <a 
                        href={link.href} 
                        target="_blank" 
                        aria-label={`Lien vers ${link.name}`} 
                        class="text-text-body-primary hover:text-gray-600 transition-colors"
                    >
                        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d={link.icon} />
                        </svg>
                    </a>
                ))}
            </div>

        </div>
    </Container>
</footer>