---
// Fichier : src/components/Hero.astro
import Container from "./Container.astro";

export interface Props {
  title: string;
  subtitle: string;
  subtitleBreak?: string;
  profileImage: any;
}

const { title, subtitle, subtitleBreak, profileImage } = Astro.props;
---

<Container>
  <section
    class="flex w-full flex-col md:flex-row items-center justify-center gap-xl"
  >
    {
      /*  <div class="mb-md md:mb-0 w-24 h-24 md:w-32 md:h-32 flex-shrink-0 rounded-full overflow-hidden">
            <img
                src={profileImage}
                alt="Image de profil du designer"
                class="object-cover w-full h-full"
            />
        </div>*/
    }

    <div
      class="flex flex-col items-center md:items-start text-center md:text-center space-y-md"
      style="width: fit-content;"
    >
      <h1 class="h-display w-full font-semibold italic text-heading-accent text-5xl md:text-6xl">
        {title}
      </h1>

      <p
        class="text-lg font-normal text-text-body-secondary w-full max-w-[610px]"
      >
        {subtitle}
        {
          subtitleBreak && (
            <span class="block">
              <span class="text-text-body-accent relative inline-block font-semibold">
                {subtitleBreak}
                
              </span>
            </span>
          )
        }
      </p>
    </div>
  </section>
</Container>