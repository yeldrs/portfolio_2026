---
import ArrowButton from "./ArrowButton.astro";
import { Image } from "astro:assets";

export interface Props {
  images: string[];
  hideArrowsOnMobile?: boolean;
}
const { images, hideArrowsOnMobile = true } = Astro.props;
if (!images || images.length === 0) return null;

// 1. Définition du glob
const assetsGlob = import.meta.glob(
  "/src/assets/projects/**/*.{png,jpg,jpeg,webp,avif}"
);

// 2. Fonction utilitaire pour résoudre le chemin stocké en fonction de chargement
const getOptimizedImageLoader = (path: string) => {
  if (!path.startsWith("/images/")) return null;
  // Construction du chemin d'asset réel
  const modulePath = `/src/assets/projects/${path.substring("/images/".length)}`;
  // Retourne la fonction de chargement ou null
  return assetsGlob[modulePath] || null;
};

// 3. Collecter et exécuter les Promises
const imagePromises = images.map((path) => {
  if (!path) return null;
  const loaderFunction = getOptimizedImageLoader(path);
  return loaderFunction ? loaderFunction() : null;
});

// 4. Attendre que toutes les promesses d'importation soient résolues
const resolvedModulesRaw = await Promise.all(imagePromises.filter(Boolean));

// Reconstruire le tableau en gardant les emplacements vides (undefined) pour l'assignation ordonnée
let resolvedIndex = 0;
// Utilisation de la syntaxe explicite pour éviter le bogue du compilateur
const resolvedCarouselModules = imagePromises.map((p) => {
  if (p === null) return undefined;
  const module = resolvedModulesRaw[resolvedIndex++] as any;
  return module?.default;
});

// --- FIN LOGIQUE D'IMAGES OPTIMISÉE ---

const allModalImages = images;

const dots = images.map((_, index) => ({
  index: index,
}));

// Classes du Design System (DS) pour les Props
const DS_CLASSES = {
  mainDefault: "stroke-primary",
  mainHover: "stroke-primary-hover",
  tertiaryDefault: "stroke-tertiary",
  tertiaryHover: "stroke-tertiary-hover",
  disabledColor: "stroke-disabled",
} as const;

const prevInitialVariant = "disabled";
const activeVariant = "main";
---

<section
  id="project-carousel"
  aria-label="Project Image Carousel"
  class="space-y-md my-3xl"
>
  <div class="flex items-center justify-between">
    {/* ⬅️ Flèche Précédente (Desktop) */}
    <ArrowButton
      id="prevBtn"
      label="Image précédente"
      direction="left"
      variant={prevInitialVariant as any}
      onClick="window.handleCarouselNavigation(-1)"
      isMobile={false}
      {...DS_CLASSES}
      class={hideArrowsOnMobile ? "hidden md:block" : ""}
    />

    {
      /* 🖼️ Conteneur principal de l'image (relative pour positionner les images en absolu) */
    }
    <div
      class:list={[
        "relative w-full rounded-2xl overflow-hidden bg-background-primary aspect-video",
        "mx-0",
        { "md:mx-md": hideArrowsOnMobile },
      ]}
    >
      {
        /* Le rendu des images utilise les modules résolus et gère les classes de visibilité */
      }
      {
        // Utilisation du bloc explicite pour contourner le bug du compilateur
        resolvedCarouselModules.map((module, index) => {
          if (!module) return null;

          return (
            <div
              data-carousel-index={index}
              class:list={[
                "absolute inset-0 transition-opacity duration-300",
                index === 0 ? "opacity-100 z-10" : "opacity-0 z-0",
              ]}
            >
              <Image
                src={module}
                alt={`Image détaillée du projet #${index + 1}`}
                width={1000}
                format="webp"
                class="w-full h-full object-contain object-center block rounded-2xl cursor-pointer"
                loading={index === 0 ? "eager" : "lazy"}
                onclick={`showImageModal('${allModalImages[index]}')`}
              />
            </div>
          );
        })
      }
    </div>

    {/* ➡️ Flèche Suivante (Desktop) */}
    <ArrowButton
      id="nextBtn"
      label="Image suivante"
      direction="right"
      variant={activeVariant as any}
      onClick="window.handleCarouselNavigation(1)"
      isMobile={false}
      {...DS_CLASSES}
      class={hideArrowsOnMobile ? "hidden md:block" : ""}
    />
  </div>

  {/* 🔴 Indicateurs de points (Dots) et Flèches Mobile */}
  <div class="flex items-center justify-center pt-4">
    {/* ⬅️ Flèche Mobile Précédente */}
    <ArrowButton
      id="prevBtnMobile"
      label="Image précédente"
      direction="left"
      variant={prevInitialVariant as any}
      onClick="window.handleCarouselNavigation(-1)"
      isMobile={true}
      {...DS_CLASSES}
    />

    {/* Conteneur des Points */}
    <div id="carouselDots" class="flex justify-center space-x-2 mx-4">
      {
        dots.map((dot) => (
          <button
            data-index={dot.index}
            aria-label={`Go to slide ${dot.index + 1}`}
            class={`w-3 h-3 rounded-full transition-colors ${dot.index === 0 ? "bg-background-accent-primary" : "bg-background-disabled"}`}
            onclick={`window.updateImageFromDot(${dot.index})`}
          />
        ))
      }
    </div>

    {/* ➡️ Flèche Mobile Suivante */}
    <ArrowButton
      id="nextBtnMobile"
      label="Image suivante"
      direction="right"
      variant={activeVariant as any}
      onClick="window.handleCarouselNavigation(1)"
      isMobile={true}
      {...DS_CLASSES}
    />
  </div>
</section>

<script define:vars={{ allModalImages }} is:inline>
  // --- LOGIQUE JS DU CARROUSEL (Manipulation de classes/visibilité) ---

  let isInitialized = false;
  const TOTAL_IMAGES = allModalImages.length;
  let currentIndex = 0; // État de l'image actuellement visible

  window.updateImageFromDot = function (index) {
    updateImage(index);
  };

  window.handleCarouselNavigation = function (direction) {
    if (TOTAL_IMAGES === 0) return;

    let newIndex = currentIndex + direction;

    if (direction === 1) {
      if (newIndex >= TOTAL_IMAGES) {
        newIndex = 0; // Loop vers la première image
      }
    } else if (direction === -1) {
      if (newIndex < 0) {
        return; // Arrête la navigation
      }
    }

    updateImage(newIndex);
  };

  // FONCTION DE MISE À JOUR (Portée Locale)
  function updateImage(index) {
    const dotsContainer = document.getElementById("carouselDots");
    // Sélecteur cible le conteneur relatif qui contient toutes les images
    const carouselContainer = document.querySelector(
      "#project-carousel .relative"
    );

    if (!dotsContainer || !carouselContainer || TOTAL_IMAGES === 0) return;

    // 1. Mise à jour de l'image (via la manipulation des classes de visibilité/z-index)
    carouselContainer
      .querySelectorAll("[data-carousel-index]")
      .forEach((wrapper) => {
        const wrapperIndex = parseInt(
          wrapper.getAttribute("data-carousel-index") || "0"
        );
        const isActive = wrapperIndex === index;

        // Gérer la visibilité (opacity) et l'ordre (z-index)
        wrapper.classList.toggle("opacity-100", isActive);
        wrapper.classList.toggle("z-10", isActive);
        wrapper.classList.toggle("opacity-0", !isActive);
        wrapper.classList.toggle("z-0", !isActive);

        // Mettre à jour l'onclick de l'image visible (pointe vers le chemin brut pour la modale)
        const imageElement = wrapper.querySelector("img");
        if (isActive && imageElement) {
          imageElement.setAttribute(
            "onclick",
            `showImageModal('${allModalImages[index]}')`
          );
        }
      });

    currentIndex = index; // Mettre à jour l'état global

    // 2. Mise à jour des points
    dotsContainer.querySelectorAll("button").forEach((dot, dotIndex) => {
      const isActive = dotIndex === index;
      dot.classList.toggle("bg-background-accent-primary", isActive);
      dot.classList.toggle("bg-background-disabled", !isActive);
    });

    // 3. Mise à jour des États des Flèches (Précédent)
    const prevArrows = [
      document.getElementById("prevBtn"),
      document.getElementById("prevBtnMobile"),
    ];
    const isPrevDisabled = index === 0;

    prevArrows.forEach((btn) => {
      if (!btn) return;
      btn.disabled = isPrevDisabled;
      const span = btn.querySelector("span");
      if (span) {
        span.classList.toggle("opacity-0", isPrevDisabled);
        span.classList.toggle("pointer-events-none", isPrevDisabled);
        span.classList.toggle("opacity-100", !isPrevDisabled);
      }
    });
  }

  // GESTION DU SWIPE (Portée Locale)
  function attachSwipeHandler() {
    const carouselContainer = document.querySelector(
      "#project-carousel .relative"
    );
    if (!carouselContainer) return;

    let touchstartX = 0;
    let touchendX = 0;
    const minSwipeDistance = 50;

    carouselContainer.addEventListener("touchstart", (e) => {
      touchstartX = e.changedTouches[0].screenX;
    });

    carouselContainer.addEventListener("touchend", (e) => {
      touchendX = e.changedTouches[0].screenX;
      handleSwipeGesture();
    });

    function handleSwipeGesture() {
      const distance = touchendX - touchstartX;

      if (Math.abs(distance) < minSwipeDistance) {
        return;
      }

      if (distance < 0) {
        // Swipe vers la gauche (passe à l'image suivante: direction 1)
        window.handleCarouselNavigation(1);
      } else {
        // Swipe vers la droite (passe à l'image précédente: direction -1)
        window.handleCarouselNavigation(-1);
      }
    }
  }

  // Fonction d'initialisation (Portée Locale)
  function initializeCarousel() {
    if (isInitialized || allModalImages.length === 0) return;

    updateImage(0);
    attachSwipeHandler();

    isInitialized = true;
  }

  document.addEventListener("DOMContentLoaded", initializeCarousel);
  document.addEventListener("astro:after-swap", initializeCarousel);
</script>
