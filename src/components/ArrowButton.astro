---
export interface Props {
direction: 'left' | 'right';
variant?: 'main' | 'tertiary' | 'disabled';
onClick?: string; 
id?: string; // <- made optional
label: string;
isMobile?: boolean; 
isHidden?: boolean; 
class?: string; 
disabled?: boolean;

// These props will NOT be used for visual display temporarily
mainDefault: string; 
mainHover: string; 
tertiaryDefault: string; 
tertiaryHover: string; 
disabledColor: string; 
}

const { 
direction, 
variant = 'main', 
onClick, 
id, 
label, 
isMobile = false, 
isHidden = false,
class: className = '', // default to empty string
disabled = false,
// The color props are extracted but ignored for styling
mainDefault,
mainHover,
tertiaryDefault,
tertiaryHover,
disabledColor,
} = Astro.props;

// 1. Determine the state and invisibility classes
let opacityClass = '';
let pointerEvents = '';

const isDisabled = disabled || variant === 'disabled'; 

if (isDisabled) {
    // Makes the arrow invisible and non-clickable
    opacityClass = 'opacity-0'; 
    pointerEvents = 'pointer-events-none';
} else {
    // Stays visible and clickable
    opacityClass = 'opacity-100'; 
    pointerEvents = '';
}

// 2. SVG definition (Back to the simple version with stroke="currentColor" for black)
const ArrowSVGContent = `
<svg width="24" height="43" viewBox="0 0 24 43" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M1.5 1.5L21.5 21.5L1.5 41.5" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
</svg>
`;

// 3. Determine the rotation (default SVG points right)
const rotationClass = direction === 'left' ? 'transform rotate-180' : '';

// 4. Display classes
// Temporarily fixed to ensure visibility on the debugging screen:
const displayClasses = isMobile ? 'block sm:hidden' : 'block sm:block'; 
const hiddenClass = isHidden ? 'hidden' : '';

const baseClasses = `p-2 transition-opacity ${displayClasses} ${hiddenClass}`;
---

<button 
id={id ?? undefined} 
aria-label={label} 
class={`${baseClasses} ${className || ''}`} 
onclick={onClick} 
disabled={isDisabled} 
data-variant={variant}
>
<span 
    class={`h-full w-full block ${rotationClass} ${opacityClass} ${pointerEvents}`} 
    aria-hidden="true" 
    set:html={ArrowSVGContent}
>
</span>
</button>