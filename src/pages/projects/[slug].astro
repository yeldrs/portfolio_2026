---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import ProjectCarousel from "../../components/ProjectCarousel.astro";
import ArrowButton from "../../components/ArrowButton.astro";

// 💡 Importation de la composante Image et du NOUVEAU composant Modale
import { Image } from "astro:assets";
import ImageModal from "../../components/ImageModal.astro";

// Générer les chemins statiques à partir des fichiers MDX
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

// Récupération de l'entrée de collection et du contenu rendu
const { project } = Astro.props;
const { Content } = await project.render();

// --- LOGIQUE D'IMAGES OPTIMISÉE POUR TOUTES LES IMAGES (Astro Assets) ---

const projectImagesPaths = project.data.projectImages || [];

// 1. Définition du glob
const assetsGlob = import.meta.glob(
  "/src/assets/projects/**/*.{png,jpg,jpeg,webp,avif}"
);

// 2. Fonction utilitaire pour résoudre le chemin stocké en fonction de chargement
const getOptimizedImageLoader = (path: string) => {
  if (!path.startsWith("/images/")) return null;
  const modulePath = `/src/assets/projects/${path.substring("/images/".length)}`;
  return assetsGlob[modulePath] || null;
};

// 3. Collecter et exécuter les Promises pour TOUTES les images (PAS seulement les 8 premières)
const imagePromises = projectImagesPaths.map((path) => {
  if (!path) return null; // Placeholders vides
  const loaderFunction = getOptimizedImageLoader(path);
  return loaderFunction ? loaderFunction() : null;
});

// 4. Attendre que toutes les promesses d'importation soient résolues
const resolvedModulesRaw = await Promise.all(imagePromises.filter(Boolean));

// Reconstruire le tableau complet des modules d'images résolus
let resolvedIndex = 0;
const allResolvedImageModules = imagePromises.map((p) => {
  if (p === null) {
    return undefined;
  }
  // @ts-ignore : on sait que le module résolu aura un `default` contenant les métadonnées de l'image.
  const module = resolvedModulesRaw[resolvedIndex++] as any;
  return module?.default;
});

// Assigner les 8 premiers modules résolus aux variables d'affichage direct
const contextImageModule = allResolvedImageModules[0];
const contextImage2Module = allResolvedImageModules[1];
const roleImageModule = allResolvedImageModules[2];
const roleImage2Module = allResolvedImageModules[3];
const conceptionImageModule = allResolvedImageModules[4];
const conceptionImage2Module = allResolvedImageModules[5];
const resultsImageModule = allResolvedImageModules[6];
const resultsImage2Module = allResolvedImageModules[7];

// Le carrousel utilise les chemins bruts pour le composant ProjectCarousel.
// (Sauf si vous mettez à jour ProjectCarousel pour utiliser des modules résolus)
const carouselImages = projectImagesPaths.slice(8);

// La liste d'images pour la modale doit contenir TOUS les modules résolus (les URLs optimisées).
// C'est cette liste que nous passons au composant ImageModal.
const allModalImagesURLs = allResolvedImageModules
  .filter(Boolean)
  .map((mod) => mod.src);

// --- Fin de la Logique d'images optimisée ---

// --- Type Narrowing pour les champs optionnels (Aucun changement) ---
const teamMembers = project.data.teamMembers || [];
const references = project.data.references || [];
const designConceptionList = project.data.designConception?.listItems || [];

// --- Classes du Design System (DS) pour les Props (Aucun changement) ---
const DS_CLASSES = {
  mainDefault: "stroke-primary",
  mainHover: "stroke-primary-hover",
  tertiaryDefault: "stroke-tertiary",
  tertiaryHover: "stroke-tertiary-hover",
  disabledColor: "stroke-disabled",
};

const tertiaryVariant = "tertiary";
const disabledVariant = "disabled";
---

<BaseLayout title={`Project | ${project.data.title}`}>
  <Container>
    <main class="py-3xl max-w-content mx-auto space-y-3xl">
      <h1 class="text-4xl font-extrabold text-text-body-primary">
        {project.data.title}
      </h1>

      <div class="prose prose-lg dark:prose-invert">
        <Content />
      </div>

      <section
        id={`${project.slug}-diagnosis`}
        role="region"
        aria-label="Diagnosis"
        class="space-y-3xl"
      >
        <h2 class="text-3xl font-normal text-text-body-primary mb-3xl">
          Diagnosis
        </h2>

        <article
          id={`${project.slug}-context-problem`}
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Context
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.context}
              </p>
            </div>

            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Problem
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.problem}
              </p>
            </div>
          </div>

          {
            /* NOUVEAU CONTENEUR D'IMAGES pour Context/Problem (Utilise <Image /> et appelle la modale avec l'URL résolue) */
          }
          <div class="space-y-md">
            {
              contextImageModule && (
                <div
                  onclick={`showImageModal('${contextImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={contextImageModule}
                    alt="Context and problem visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              contextImage2Module && (
                <div
                  onclick={`showImageModal('${contextImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={contextImage2Module}
                    alt="Context and problem visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>

        <article
          id={`${project.slug}-role-insights`}
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Role
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.roleDescription}
              </p>
            </div>
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Key insights
              </h3>
              {
                Array.isArray(project.data.keyInsights) ? (
                  <ul class="list-disc pl-5 text-base text-text-body leading-relaxed text-left">
                    {project.data.keyInsights.map((insight) => (
                      <li set:html={insight} />
                    ))}
                  </ul>
                ) : (
                  <div
                    set:html={project.data.keyInsights}
                    class="text-base text-text-body leading-relaxed text-left"
                  />
                )
              }
            </div>
          </div>

          {
            /* NOUVEAU CONTENEUR D'IMAGES pour Role/Insights (Utilise <Image /> et appelle la modale avec l'URL résolue) */
          }
          <div class="space-y-md">
            {
              roleImageModule && (
                <div
                  onclick={`showImageModal('${roleImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={roleImageModule}
                    alt="Role and insights visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              roleImage2Module && (
                <div
                  onclick={`showImageModal('${roleImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={roleImage2Module}
                    alt="Role and insights visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>
      </section>

      {
        /* Le carrousel garde les chemins bruts et le onclick devra être géré dans ProjectCarousel pour utiliser l'URL optimisée */
      }
      <ProjectCarousel images={carouselImages} hideArrowsOnMobile={true} />

      <section
        id={`${project.slug}-conception`}
        role="region"
        aria-label="Conception"
        class="space-y-3xl"
      >
        <h2 class="text-3xl font-normal text-text-body-primary mb-3xl">
          Conception
        </h2>

        <article
          id="conception-main"
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Methodology
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.methodology}
              </p>
            </div>

            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Design conception
              </h3>
              {
                project.data.designConception?.paragraph && (
                  <div
                    set:html={project.data.designConception.paragraph}
                    class="text-base text-text-body leading-relaxed text-left"
                  />
                )
              }
              {
                designConceptionList.length > 0 && (
                  <ul class="list-disc pl-5 text-base text-text-body leading-relaxed text-left">
                    {designConceptionList.map((item) => (
                      <li set:html={item} />
                    ))}
                  </ul>
                )
              }
            </div>
          </div>

          {
            /* NOUVEAU CONTENEUR D'IMAGES pour Conception (Utilise <Image /> et appelle la modale avec l'URL résolue) */
          }
          <div class="space-y-md">
            {
              conceptionImageModule && (
                <div
                  onclick={`showImageModal('${conceptionImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={conceptionImageModule}
                    alt="Conception visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              conceptionImage2Module && (
                <div
                  onclick={`showImageModal('${conceptionImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={conceptionImage2Module}
                    alt="Conception visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>
      </section>

      <section
        id={`${project.slug}-results`}
        role="region"
        aria-label="Results"
        class="space-y-3xl"
      >
        <h2 class="text-3xl font-normal text-text-body-primary mb-3xl">
          Results
        </h2>

        <article
          id={`${project.slug}-results-main`}
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Delivery
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.delivery}
              </p>
            </div>

            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Metrics
              </h3>
              {
                Array.isArray(project.data.metrics) ? (
                  <ul class="list-disc pl-5 text-base text-text-body leading-relaxed text-left">
                    {project.data.metrics.map((metric) => (
                      <li set:html={metric} />
                    ))}
                  </ul>
                ) : (
                  <div
                    set:html={project.data.metrics}
                    class="text-base text-text-body leading-relaxed text-left"
                  />
                )
              }
            </div>
          </div>

          {
            /* NOUVEAU CONTENEUR D'IMAGES pour Results (Utilise <Image /> et appelle la modale avec l'URL résolue) */
          }
          <div class="space-y-md">
            {
              resultsImageModule && (
                <div
                  onclick={`showImageModal('${resultsImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={resultsImageModule}
                    alt="Results visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              resultsImage2Module && (
                <div
                  onclick={`showImageModal('${resultsImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={resultsImage2Module}
                    alt="Results visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>
      </section>

      {/* ---------------------------------------------------- */}
      {/* SECTION CRÉDITS (Aucun changement) */}
      {/* ---------------------------------------------------- */}

      {
        (project.data.clientDetails?.name ||
          teamMembers.length > 0 ||
          references.length > 0) && (
          <section
            id={`${project.slug}-credits`}
            role="contentinfo"
            aria-label="Crédits et Références"
            class="space-y-sm text-text-body-secondary mt-3xl border-t border-border-secondary pt-3xl"
          >
            <h2 class="text-base font-semibold text-text-body-primary">
              Credits & References
            </h2>

            <div class="text-xs space-y-xxs">
              <p>
                <>
                  <strong>Author and conceptor : </strong>
                  <a
                    href="https://www.linkedin.com/in/yassineelidrissi/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline hover:text-text-body-primary transition-colors"
                  >
                    Yassine El Idrissi
                  </a>
                </>
              </p>

              {/* Ligne 1 : Équipe (teamMembers) */}
              <p>
                <strong>In collaboration with :</strong>
                {teamMembers.map((member, index) => {
                  if (!member.name) return null;
                  return (
                    <span>
                      <a
                        href={member.link || "#"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline hover:text-text-body-primary transition-colors"
                      >
                        {member.name}
                      </a>
                      {member.role && <span>, {member.role}</span>}
                      {index < teamMembers.length - 2
                        ? ", "
                        : index === teamMembers.length - 2
                          ? " et "
                          : ""}
                    </span>
                  );
                })}
              </p>

              {/* Ligne 2 : Client (Affiche si clientDetails existe ET si le nom du client existe) */}
              {project.data.clientDetails?.name && (
                <p>
                  <strong>Client :</strong>{" "}
                  <a
                    href={project.data.clientDetails.link || "#"}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline hover:text-text-body-primary transition-colors"
                  >
                    {project.data.clientDetails.name}
                  </a>
                  .
                </p>
              )}

              {/* Ligne 3 : Références/Mentors */}
              {references.length > 0 && (
                <p>
                  <strong>References :</strong>
                  {references.map((ref, index) => {
                    if (!ref.name) return null;
                    return (
                      <span>
                        <a
                          href={ref.link || "#"}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="underline hover:text-text-body-primary transition-colors"
                        >
                          {ref.name}
                        </a>
                        {ref.role && <span>, {ref.role}</span>}
                        {index < references.length - 1 ? " | " : ""}
                      </span>
                    );
                  })}
                </p>
              )}
            </div>
          </section>
        )
      }
    </main>
  </Container>

  {
    /* 🚨 NOUVEAU: Inclusion du composant modale en lui passant la liste d'URLs optimisées */
  }
  <ImageModal images={allModalImagesURLs} DS_CLASSES={DS_CLASSES} />
</BaseLayout>

{/* 🚨 SUPPRESSION de l'ancien bloc div#imageModal et du <script> associé */}
