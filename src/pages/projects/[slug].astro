---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

// Générer les chemins statiques à partir des fichiers MDX
export async function getStaticPaths() {
const projects = await getCollection('projects');
return projects.map(project => ({
 params: { slug: project.slug },
 props: { project },
}));
}

const { project } = Astro.props;
const { Content } = await project.render();

// 🚨 RÉCUPÉRATION DES IMAGES
// Nous allons utiliser le tableau projectImages pour la galerie,
// et les 4 premières images pour les sections Context/Role/Conception/Results
const projectImages = project.data.projectImages || [];

// Attribuer les 4 premières images du tableau aux sections
// Si l'image n'existe pas, on utilise un fallback (carte image ou chaîne vide)
const contextImage = projectImages[0] || project.data.cardImage || ''; // Utilise la cardImage comme fallback
const roleImage = projectImages[1] || '';
const conceptionImage = projectImages[2] || '';
const resultsImage = projectImages[3] || '';

// Le reste des images pour la galerie
// Le code ci-dessous n'est pas utilisé dans le HTML final ci-dessous, 
// mais je le garde car il était présent dans votre frontmatter
const galleryImages = projectImages.slice(4); 
---

<BaseLayout title={`Project | ${project.data.title}`}>
 <Container>
   <main class="py-3xl max-w-content mx-auto space-y-3xl">
    <h1 class="text-6xl font-extrabold text-text-body-primary mb-xl">
      {project.data.title}
     </h1>

    <div class="prose prose-lg dark:prose-invert">
     <Content />
    </div>

    <div class="space-y-3xl">
      <section id={`${project.slug}-diagnosis`} role="region" aria-label="Diagnosis" class="space-y-2xl">
       <h2 class="text-4xl font-extrabold text-text-body-primary mb-xl">Diagnosis</h2>

       <article id={`${project.slug}-context`} role="article"
      aria-labelledby={`${project.slug}-context-title`} class="grid grid-cols-1 md:grid-cols-2 gap-xl mb-2xl">
         <div class="space-y-lg">
          <div class="space-y-sm">
            <h3 id={`${project.slug}-context-title`}
         class="text-xl font-semibold text-text-body-primary">Context</h3>
            <p class="text-base text-text-body-secondary leading-relaxed">{project.data.context}</p>
           </div>
          <div class="space-y-sm">
            <h3 class="text-xl font-semibold text-text-body-primary">Problem</h3>
            <p class="text-base text-text-body-secondary leading-relaxed">{project.data.problem}</p>
           </div>
          </div>

         <div class="relative w-full rounded-2xl overflow-hidden bg-background-primary aspect-[19/9]">
          <img src={contextImage} alt="Context and problem visualization"
        class="w-full h-full object-cover object-center block rounded-2xl" loading="lazy" />
          </div>
        </article>

       <article id={`${project.slug}-role-insights`} role="article"
      aria-labelledby={`${project.slug}-role-title`} class="grid grid-cols-1 md:grid-cols-2 gap-xl items-start">
         <div class="relative w-full rounded-2xl overflow-hidden bg-background-primary aspect-[19/9]">
          <img src={roleImage} alt="Role and insights visualization"
        class="w-full h-full object-cover object-center block rounded-2xl" loading="lazy" />
          </div>

         <div class="space-y-lg flex flex-col justify-start">
          <div class="space-y-sm">
            <h3 id={`${project.slug}-role-title`}
         class="text-xl font-semibold text-text-body-primary">Role</h3>
            <p class="text-base text-text-body-secondary leading-relaxed">
         {project.data.roleDescription}</p>
           </div>
          <div class="space-y-sm">
            <h3 class="text-xl font-semibold text-text-body-primary">Key insights</h3>
            <ul class="list-disc pl-5 text-base text-text-body-secondary leading-relaxed">
         {project.data.keyInsights.map(insight => <li>{insight}</li>)}
        </ul>
           </div>
          </div>
        </article>
       </section>

      <section id={`${project.slug}-conception`} role="region" aria-label="Conception" class="space-y-2xl">
       <h2 class="text-4xl font-extrabold text-text-body-primary mb-xl">Conception</h2>

       <article id={`${project.slug}-conception-main`} role="article"
      class="grid grid-cols-1 md:grid-cols-2 gap-xl items-start">
         <div class="space-y-lg">
          <div class="space-y-sm">
            <h3 class="text-xl font-semibold text-text-body-primary">Methodology</h3>
            <p class="text-base text-text-body-tertiary leading-relaxed">{project.data.methodology}
        </p>
           </div>

          <div class="space-y-sm">
            <h3 class="text-xl font-semibold text-text-body-primary">Design conception</h3>
            <p class="text-base text-text-body-tertiary leading-relaxed">
         {project.data.designConception}</p>
           </div>
          </div>

         <div class="relative w-full rounded-2xl overflow-hidden bg-background-primary aspect-[19/9]">
          <img src={conceptionImage} alt="Conception visualization"
        class="w-full h-full object-cover object-center block rounded-2xl" loading="lazy" />
          </div>
        </article>
       </section>

      <section id={`${project.slug}-results`} role="region" aria-label="Results" class="space-y-2xl">
       <h2 class="text-4xl font-extrabold text-text-body-primary mb-xl">Results</h2>

       <article id={`${project.slug}-results-main`} role="article"
      class="grid grid-cols-1 md:grid-cols-2 gap-xl items-start">
         <div class="space-y-lg">
          <div class="space-y-sm">
            <h3 class="text-xl font-semibold text-text-body-primary">Delivery</h3>
            <p class="text-base text-text-body-tertiary leading-relaxed">{project.data.delivery}
        </p>
           </div>

          <div class="space-y-sm">
            <h3 class="text-xl font-semibold text-text-body-primary">Metrics</h3>
            <p class="text-base text-text-body-tertiary leading-relaxed">{project.data.metrics}</p>
           </div>
          </div>




         <div class="relative w-full rounded-2xl overflow-hidden bg-background-primary aspect-[19/9]">
          <img src={resultsImage} alt="Results visualization"
        class="w-full h-full object-cover object-center block rounded-2xl" loading="lazy" />
          </div>
        </article>
       </section>
   </div>
   {/* --- SÉLECTION DE LA GALERIE D'IMAGES 
   {projectImages.length > 0 && (
   <section id={`${project.slug}-gallery`} role="region" aria-label="Gallery" class="space-y-3xl pt-5xl">
    <h2 class="text-4xl font-extrabold text-text-body-primary border-t pt-lg">Galerie</h2>
    <div class="space-y-5xl">
     {projectImages.map((imageUrl) => (
     <div class="w-full rounded-xl overflow-hidden shadow-2xl">
      <img src={imageUrl} alt={`Image de détail pour le projet ${project.data.title}`} loading="lazy"
       class="w-full h-auto block" />
     </div>
     ))}
    </div>
   </section>
   )} ---*/}
  </main>
  </Container>
</BaseLayout>

<style>
 .prose {
  max-width: none;
 }
</style>