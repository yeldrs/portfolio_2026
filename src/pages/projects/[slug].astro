---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import ProjectCarousel from "../../components/ProjectCarousel.astro";
import ArrowButton from "../../components/ArrowButton.astro";

// 💡 Importation simple de la composante Image
import { Image } from "astro:assets";

// Générer les chemins statiques à partir des fichiers MDX
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

// Récupération de l'entrée de collection et du contenu rendu
const { project } = Astro.props;
const { Content } = await project.render();

// --- LOGIQUE D'IMAGES OPTIMISÉE (Astro Assets) ---

const projectImagesPaths = project.data.projectImages || [];

// 1. Définition du glob
const assetsGlob = import.meta.glob(
  "/src/assets/projects/**/*.{png,jpg,jpeg,webp,avif}"
);

// 2. Fonction utilitaire pour résoudre le chemin stocké en fonction de chargement
const getOptimizedImageLoader = (path: string) => {
  if (!path.startsWith("/images/")) return null;

  // Construction du chemin d'asset réel
  const modulePath = `/src/assets/projects/${path.substring("/images/".length)}`;

  // Retourne la fonction de chargement ou null
  return assetsGlob[modulePath] || null;
};

// 3. Collecter et exécuter les Promises
const imagePromises = projectImagesPaths.slice(0, 8).map((path) => {
  if (!path) return null; // Placeholders vides
  const loaderFunction = getOptimizedImageLoader(path);

  // Si la fonction de chargement existe, on l'appelle pour obtenir la Promise
  return loaderFunction ? loaderFunction() : null;
});

// 4. Attendre que toutes les promesses d'importation soient résolues
const resolvedModulesRaw = await Promise.all(imagePromises.filter(Boolean));

// Reconstruire le tableau en gardant les emplacements vides (undefined) pour l'assignation ordonnée
let resolvedIndex = 0;
// 🚨 CORRECTION CRITIQUE: Nous forçons le type résolu à avoir la propriété 'default'
const resolvedImageModules = imagePromises.map((p) => {
  if (p === null) {
    return undefined;
  }

  // Utilisation de `as any` pour désactiver l'erreur 'Property 'default' does not exist on type '{}'.'
  const module = resolvedModulesRaw[resolvedIndex++] as any;

  return module?.default;
});

// Assigner les modules résolus aux variables
// Note: Si le module est undefined, le && dans le template ignorera la balise <Image />
const contextImageModule = resolvedImageModules[0];
const contextImage2Module = resolvedImageModules[1];
const roleImageModule = resolvedImageModules[2];
const roleImage2Module = resolvedImageModules[3];
const conceptionImageModule = resolvedImageModules[4];
const conceptionImage2Module = resolvedImageModules[5];
const resultsImageModule = resolvedImageModules[6];
const resultsImage2Module = resolvedImageModules[7];

// Le carrousel et la modale continuent d'utiliser les chemins originaux
const carouselImages = projectImagesPaths.slice(8);

// La liste des images modales doit inclure les chemins résolus pour les 8 premières images
// si elles utilisent <Image /> et leurs chemins bruts (pour la navigation JS)
// ATTENTION: Le JS utilise `projectImagesPaths` (les chemins bruts) comme liste de référence.
const allModalImages = projectImagesPaths; // Le JS dépend de cette liste de chemins bruts pour l'index

// --- Fin de la Logique d'images optimisée ---

// --- Type Narrowing pour les champs optionnels (Aucun changement) ---
const teamMembers = project.data.teamMembers || [];
const references = project.data.references || [];
const designConceptionList = project.data.designConception?.listItems || [];

// --- Classes du Design System (DS) pour les Props (Aucun changement) ---
const DS_CLASSES = {
  mainDefault: "stroke-primary",
  mainHover: "stroke-primary-hover",
  tertiaryDefault: "stroke-tertiary",
  tertiaryHover: "stroke-tertiary-hover",
  disabledColor: "stroke-disabled",
};

const tertiaryVariant = "tertiary";
const disabledVariant = "disabled";
---

<BaseLayout title={`Project | ${project.data.title}`}>
  <Container>
    <main class="py-3xl max-w-content mx-auto space-y-3xl">
      <h1 class="text-4xl font-extrabold text-text-body-primary">
        {project.data.title}
      </h1>

      <div class="prose prose-lg dark:prose-invert">
        <Content />
      </div>

      <section
        id={`${project.slug}-diagnosis`}
        role="region"
        aria-label="Diagnosis"
        class="space-y-3xl"
      >
        <h2 class="text-3xl font-normal text-text-body-primary mb-3xl">
          Diagnosis
        </h2>

        <article
          id={`${project.slug}-context-problem`}
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Context
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.context}
              </p>
            </div>

            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Problem
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.problem}
              </p>
            </div>
          </div>

          {
            /* NOUVEAU CONTENEUR D'IMAGES pour Context/Problem (Utilise <Image />) */
          }
          <div class="space-y-md">
            {
              contextImageModule && (
                <div
                  onclick={`showImageModal('${contextImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={contextImageModule}
                    alt="Context and problem visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              contextImage2Module && (
                <div
                  onclick={`showImageModal('${contextImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={contextImage2Module}
                    alt="Context and problem visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>

        <article
          id={`${project.slug}-role-insights`}
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Role
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.roleDescription}
              </p>
            </div>
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Key insights
              </h3>
              {
                Array.isArray(project.data.keyInsights) ? (
                  <ul class="list-disc pl-5 text-base text-text-body leading-relaxed text-left">
                    {project.data.keyInsights.map((insight) => (
                      <li set:html={insight} />
                    ))}
                  </ul>
                ) : (
                  <div
                    set:html={project.data.keyInsights}
                    class="text-base text-text-body leading-relaxed text-left"
                  />
                )
              }
            </div>
          </div>

          {
            /* NOUVEAU CONTENEUR D'IMAGES pour Role/Insights (Utilise <Image />) */
          }
          <div class="space-y-md">
            {
              roleImageModule && (
                <div
                  onclick={`showImageModal('${roleImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={roleImageModule}
                    alt="Role and insights visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              roleImage2Module && (
                <div
                  onclick={`showImageModal('${roleImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={roleImage2Module}
                    alt="Role and insights visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>
      </section>

      <ProjectCarousel images={carouselImages} hideArrowsOnMobile={true} />

      <section
        id={`${project.slug}-conception`}
        role="region"
        aria-label="Conception"
        class="space-y-3xl"
      >
        <h2 class="text-3xl font-normal text-text-body-primary mb-3xl">
          Conception
        </h2>

        <article
          id="conception-main"
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Methodology
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.methodology}
              </p>
            </div>

            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Design conception
              </h3>
              {/* AFFICHAGE CONDITIONNEL DU PARAGRAPHE */}
              {
                project.data.designConception?.paragraph && (
                  <div
                    set:html={project.data.designConception.paragraph}
                    class="text-base text-text-body leading-relaxed text-left"
                  />
                )
              }
              {/* AFFICHAGE CONDITIONNEL DE LA LISTE */}
              {
                designConceptionList.length > 0 && (
                  <ul class="list-disc pl-5 text-base text-text-body leading-relaxed text-left">
                    {designConceptionList.map((item) => (
                      <li set:html={item} />
                    ))}
                  </ul>
                )
              }
            </div>
          </div>

          {/* NOUVEAU CONTENEUR D'IMAGES pour Conception (Utilise <Image />) */}
          <div class="space-y-md">
            {
              conceptionImageModule && (
                <div
                  onclick={`showImageModal('${conceptionImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={conceptionImageModule}
                    alt="Conception visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              conceptionImage2Module && (
                <div
                  onclick={`showImageModal('${conceptionImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={conceptionImage2Module}
                    alt="Conception visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>
      </section>

      <section
        id={`${project.slug}-results`}
        role="region"
        aria-label="Results"
        class="space-y-3xl"
      >
        <h2 class="text-3xl font-normal text-text-body-primary mb-3xl">
          Results
        </h2>

        <article
          id={`${project.slug}-results-main`}
          role="article"
          class="grid grid-cols-1 md:grid-cols-2 gap-y-3xl md:gap-x-4xl items-start"
        >
          <div class="space-y-md">
            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Delivery
              </h3>
              <p class="text-base text-text-body leading-relaxed text-left">
                {project.data.delivery}
              </p>
            </div>

            <div class="space-y-sm">
              <h3 class="text-lg font-semibold text-text-body-secondary">
                Metrics
              </h3>
              {/* LOGIQUE CONDITIONNELLE pour Metrics */}
              {
                Array.isArray(project.data.metrics) ? (
                  <ul class="list-disc pl-5 text-base text-text-body leading-relaxed text-left">
                    {project.data.metrics.map((metric) => (
                      <li set:html={metric} />
                    ))}
                  </ul>
                ) : (
                  <div
                    set:html={project.data.metrics}
                    class="text-base text-text-body leading-relaxed text-left"
                  />
                )
              }
            </div>
          </div>

          {/* NOUVEAU CONTENEUR D'IMAGES pour Results (Utilise <Image />) */}
          <div class="space-y-md">
            {
              resultsImageModule && (
                <div
                  onclick={`showImageModal('${resultsImageModule.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={resultsImageModule}
                    alt="Results visualization"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
            {
              resultsImage2Module && (
                <div
                  onclick={`showImageModal('${resultsImage2Module.src}')`}
                  class="relative w-full rounded-2xl overflow-hidden bg-background-primary cursor-pointer block"
                >
                  <Image
                    src={resultsImage2Module}
                    alt="Results visualization secondary"
                    width={800}
                    format="webp"
                    class="w-full h-auto object-contain object-center block rounded-2xl transition-transform hover:scale-[1.02]"
                    loading="lazy"
                  />
                </div>
              )
            }
          </div>
        </article>
      </section>

      {/* ---------------------------------------------------- */}
      {/* SECTION CRÉDITS (Aucun changement) */}
      {/* ---------------------------------------------------- */}

      {
        (project.data.clientDetails?.name ||
          teamMembers.length > 0 ||
          references.length > 0) && (
          <section
            id={`${project.slug}-credits`}
            role="contentinfo"
            aria-label="Crédits et Références"
            class="space-y-sm text-text-body-secondary mt-3xl border-t border-border-secondary pt-3xl"
          >
            <h2 class="text-base font-semibold text-text-body-primary">
              Credits & References
            </h2>

            <div class="text-xs space-y-xxs">
              <p>
                <>
                  <strong>Author and conceptor : </strong>
                  <a
                    href="https://www.linkedin.com/in/yassineelidrissi/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline hover:text-text-body-primary transition-colors"
                  >
                    Yassine El Idrissi
                  </a>
                </>
              </p>

              {/* Ligne 1 : Équipe (teamMembers) */}
              <p>
                <strong>In collaboration with :</strong>
                {teamMembers.map((member, index) => {
                  if (!member.name) return null;
                  return (
                    <span>
                      <a
                        href={member.link || "#"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline hover:text-text-body-primary transition-colors"
                      >
                        {member.name}
                      </a>
                      {member.role && <span>, {member.role}</span>}
                      {index < teamMembers.length - 2
                        ? ", "
                        : index === teamMembers.length - 2
                          ? " et "
                          : ""}
                    </span>
                  );
                })}
              </p>

              {/* Ligne 2 : Client (Affiche si clientDetails existe ET si le nom du client existe) */}
              {project.data.clientDetails?.name && (
                <p>
                  <strong>Client :</strong>{" "}
                  <a
                    href={project.data.clientDetails.link || "#"}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline hover:text-text-body-primary transition-colors"
                  >
                    {project.data.clientDetails.name}
                  </a>
                  .
                </p>
              )}

              {/* Ligne 3 : Références/Mentors */}
              {references.length > 0 && (
                <p>
                  <strong>References :</strong>
                  {references.map((ref, index) => {
                    if (!ref.name) return null;
                    return (
                      <span>
                        <a
                          href={ref.link || "#"}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="underline hover:text-text-body-primary transition-colors"
                        >
                          {ref.name}
                        </a>
                        {ref.role && <span>, {ref.role}</span>}
                        {index < references.length - 1 ? " | " : ""}
                      </span>
                    );
                  })}
                </p>
              )}
            </div>
          </section>
        )
      }
    </main>
  </Container>

  <div
    id="imageModal"
    class="fixed inset-0 z-[9999] bg-black/80 hidden items-center justify-center p-4 cursor-zoom-out"
    aria-modal="true"
    role="dialog"
    onclick="window.hideImageModal()"
  >
    {/* Bouton de fermeture */}
    <button
      id="closeModalBtn"
      class="absolute top-4 right-4 text-white text-3xl z-10 p-2 leading-none hover:text-red-400"
      aria-label="Fermer la modale"
      onclick="event.stopPropagation(); window.hideImageModal();"
    >
      &times;
    </button>

    <div
      class="relative flex items-center justify-center w-full h-full"
      onclick="event.stopPropagation()"
    >
      {/* ⬅️ Flèche Précédente Modale (Aucun changement) */}
      <ArrowButton
        id="modalPrevBtn"
        label="Image précédente"
        direction="left"
        variant={disabledVariant as any}
        onClick="window.navigateModal(-1)"
        class="absolute left-0 z-10 transition-opacity disabled:opacity-30 disabled:pointer-events-none"
        {...DS_CLASSES}
      />

      {
        /* CORRECTION CRITIQUE: Réintroduction de la balise <img> avec l'ID "modalImage" */
      }
      <img
        id="modalImage"
        data-current-modal-index="0"
        alt="Agrandissement de l'image du projet"
        class="max-w-full max-h-full object-contain"
      />

      {/* ➡️ Flèche Suivante Modale (Aucun changement) */}
      <ArrowButton
        id="modalNextBtn"
        label="Image suivante"
        direction="right"
        variant={tertiaryVariant as any}
        onClick="window.navigateModal(1)"
        class="absolute right-0 z-10 transition-opacity disabled:opacity-30 disabled:pointer-events-none"
        {...DS_CLASSES}
      />
    </div>
  </div>

  <script define:vars={{ images: allModalImages }} is:inline>
    // --- Le JavaScript n'a pas été modifié car il est correct. ---

    const projectImages = images;
    const TOTAL_MODAL_IMAGES = projectImages.length;

    window.isModalOpen = false;
    window.isInitialized = false;

    window.navigateModal = function (direction) {
      const modalImg = document.getElementById("modalImage");
      if (!modalImg || TOTAL_MODAL_IMAGES <= 1 || !window.isModalOpen) return;

      let currentIndex = parseInt(modalImg.dataset.currentModalIndex) || 0;
      let newIndex = currentIndex + direction;

      if (newIndex >= TOTAL_MODAL_IMAGES || newIndex < 0) {
        return;
      }

      modalImg.src = projectImages[newIndex];
      modalImg.dataset.currentModalIndex = newIndex.toString();

      updateModalArrows(newIndex, TOTAL_MODAL_IMAGES);
    };

    window.showImageModal = function (imageUrl) {
      const modal = document.getElementById("imageModal");
      const modalImg = document.getElementById("modalImage");

      if (!modal || !modalImg || !imageUrl) return;

      if (window.isModalOpen) {
        window.hideImageModal();
      }

      // La recherche de l'index dans la liste de chemins bruts est correcte.
      const initialIndex = projectImages.indexOf(imageUrl);
      let initialModalIndex = initialIndex === -1 ? 0 : initialIndex;

      modalImg.src = imageUrl;
      modalImg.dataset.currentModalIndex = initialModalIndex.toString();

      modal.classList.remove("hidden");
      modal.classList.add("flex");
      window.isModalOpen = true;

      if (initialIndex !== -1 && TOTAL_MODAL_IMAGES > 1) {
        updateModalArrows(initialModalIndex, TOTAL_MODAL_IMAGES);
      } else {
        updateModalArrows(-1, 0);
      }

      modal.focus();
    };

    window.hideImageModal = function () {
      const modal = document.getElementById("imageModal");
      if (modal && window.isModalOpen) {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        window.isModalOpen = false;
      }
    };

    function updateModalArrows(index, total) {
      const prevBtn = document.getElementById("modalPrevBtn");
      const nextBtn = document.getElementById("modalNextBtn");

      if (!prevBtn || !nextBtn) return;

      const hideAll = total <= 1 || index === -1;

      if (hideAll) {
        prevBtn.classList.add("hidden");
        nextBtn.classList.add("hidden");
      } else {
        prevBtn.classList.remove("hidden");
        nextBtn.classList.remove("hidden");
      }

      const isPrevDisabled = index <= 0;
      prevBtn.disabled = isPrevDisabled;

      const isNextDisabled = index >= total - 1;
      nextBtn.disabled = isNextDisabled;
    }

    function attachKeyboardHandler() {
      if (window.isInitialized) return;

      document.addEventListener("keydown", (event) => {
        if (window.isModalOpen) {
          if (event.key === "Escape") {
            window.hideImageModal();
          } else if (event.key === "ArrowLeft") {
            window.navigateModal(-1);
          } else if (event.key === "ArrowRight") {
            window.navigateModal(1);
          }
        }
      });
      window.isInitialized = true;
    }

    document.addEventListener("DOMContentLoaded", () => {
      attachKeyboardHandler();
    });
    document.addEventListener("astro:after-swap", attachKeyboardHandler);
  </script>

  <style>
    .prose {
      max-width: none;
    }
  </style>
</BaseLayout>
