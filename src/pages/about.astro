---
// Importez vos Layout et composants
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Divider from "../components/Divider.astro";
import Button from "../components/Button.astro"; // Pour le bouton Contact

// Vos données pour la page
const profileImageUrl = "/images/profile-pic.webp"; // ASSUREZ-VOUS QUE CE CHEMIN EST CORRECT

// ✅ Données du CV : EXPÉRIENCES PROFESSIONNELLES (Rédaction anglaise mise à jour)
const professionalExperience: Array<{
  title: string;
  company: string;
  duration: string;
  highlights?: string[];
}> = [
  {
    title: "UX Product Designer (Apprenticeship)",
    company: "900.care - D2C Startup",
    duration: "Sept. 2024 - Sept. 2025 (Paris)",
    highlights: [
      "End-to-End role in an Agile team to maximize conversion, retention, and product discovery.",
    ],
  },
  {
    title: "Web Designer (Freelance)",
    company: "Freelance",
    duration: "2023 - 2024 (Remote)",
    highlights: [
      "Consulting services in digital strategy and Search Engine Optimization (SEO) using WordPress and WebFlow.",
    ],
  },
  {
    title: "Art Director (Freelance)",
    company: "Freelance",
    duration: "June. 2022 - Jan. 2023 (Paris)",
    highlights: [
      "Supported clients, including Maison Le Roux, on visual identity conception and brand strategy.",
    ],
  },
  {
    title: "Art Director",
    company: "Maison Le Roux - Food Industry",
    duration: "Mar. 2021 - Jul. 2022 (Paris)",
    highlights: [
      "Led brand strategy across digital and retail channels, ensuring consistency across all customer touchpoints.",
    ],
  },
];

// ✅ Données du CV : TOOLKIT (Mise à jour et ajout de compétences)
const toolkit: {
  hardSkills: { title: string; description: string }[];
  softSkills: { title: string; description: string }[];
  personalInterests: { title: string; description: string }[];
} = {
  hardSkills: [
    {
      title: "End-to-End Design",
      description:
        "From research (qualitative/quantitative) to final design delivery.",
    },
    {
      title: "Figma (Expert)",
      description:
        "High-fidelity prototyping, advanced Design System management and maintenance.",
    },
    {
      title: "Data & Analytics",
      description:
        "Reading and analysis of behavioral data (Metabase, Clarity, NPS, A/B testing).",
    },
    {
      title: "AI & Automation",
      description:
        "Use of AI tools (Gemini, ChatGPT) and automation (N8N, Make) to accelerate the design process.",
    },
    { title: "Suite Adobe (Expert)", description: "" },
    {
      title: "Accessibility",
      description:
        "Proficiency in digital accessibility standards (RGAA, WCAG).",
    },
    {
      title: "Technical Knowledge",
      description:
        "Solid knowledge of HTML/CSS, valuable for communicating with developers.",
    },
  ],
  softSkills: [
    {
      title: "Data-Driven Rigor",
      description: "Justifying design choices by metrics (A/B tests, KPIs).",
    },
    {
      title: "Agile & Autonomy",
      description:
        "Mastery of Scrum rituals and capacity to autonomously lead the Discovery process.",
    },
    {
      title: "Influence & Communication",
      description:
        "Aligning design with technical constraints (HTML/CSS) and business objectives (OKR).",
    },
  ],
  personalInterests: [
    {
      title: "GreenTech & Responsible Design",
      description: "Linking modern tools to environmental and societal issues.",
    },
    {
      title: "Health & Well-being",
      description:
        "Interest in accessibility and designing positive, well-being-focused experiences.",
    },
  ],
};

// ✅ NOUVELLE SECTION : Significant Work
const significantWork: Array<{
  title: string;
  description: string;
}> = [
  {
    title: "FoodTech - Food Autonomy",
    description:
      "Co-developed a digital service with a Data Scientist to enhance social connection and food autonomy for urban students.",
  },
  {
    title: "Responsible Digital - Caisse des Dépôts",
    description:
      "Created a methodological tool to systematize the integration of ethical, ecological, and inclusive principles into web design processes.",
  },
  {
    title: "Animal Health & Digital",
    description:
      "Designed and prototyped a digital support service for domestic animal owners (Final Project).",
  },
];

// ✅ Données du CV : FORMATION (Rédaction anglaise mise à jour)
const educationExperience: Array<{
  year: string;
  title: string;
  school: string;
}> = [
  {
    year: "2024-2025",
    title:
      "Master's Degree in UX Design & Digital Project Management (RNCP Level 7)",
    school:
      "ISCOD, France (Intensive 12-month program under an apprenticeship contract)",
  },
  {
    year: "2022",
    title: "Master in Digital Design (Bac+5 / M.A. equivalent)",
    school: "École de Design Nantes Atlantique, France",
  },
  {
    year: "2019",
    title: "Bachelor in Graphic Design (Bac+3 / B.A. equivalent)",
    school: "Quasar Institute for Advanced Design, Rome, Italy",
  },
];
---

<BaseLayout title="About Yassine El Idrissi - Product Designer">
  <main>
    <Container class="mt-xl py-3xl px-lg flex flex-col gap-3xl">
      {/* ⭐ SECTION 1: PROFIL & INTRODUCTION */}
      <section
        class="flex flex-col md:flex-row md:items-start gap-lg md:gap-xl max-w-3xl mt-[6rem]"
      >
        <div class="space-y-md flex-1">
          <h2 class="text-3xl font-extrabold text-text-body-primary">
            Hi, I'm Yassine 👋
          </h2>
          <p class="text-base text-text-body-secondary leading-relaxed">
            I’m a Product Designer and I position myself at the intersection of
            user research and business performance. I enjoy transforming precise
            user diagnostics into concrete solutions that improve conversion,
            increase retention, and maximize customer value.
          </p>
          <p class="text-base text-text-body-secondary leading-relaxed">
            I design useful and accessible products, ensuring that every design
            decision serves as a growth lever, while always being mindful of our
            societal and environmental impact.
          </p>
          <Button href="/contact" class="mt-lg">Let's Connect</Button>
        </div>
        <div
          class="flex-shrink-0 w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden self-center md:self-auto"
        >
          <img
            src={profileImageUrl}
            alt="Yassine El Idrissi - Profile Picture"
            class="w-full h-full object-cover"
          />
        </div>
      </section>

      <Divider />

      {/* ⭐ SECTION 2: EXPÉRIENCES PROFESSIONNELLES */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">Experience</h2>
        {
          professionalExperience.map((exp) => (
            <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start">
                <h3 class="text-base font-semibold text-text-body-primary">
                  {exp.title}
                </h3>
              </div>
              <p class="text-sm font-normal text-text-body-primary mb-md">
                {exp.company}
              </p>
              {/* Affichage des highlights en un seul paragraphe (Description) */}
              {exp.highlights && exp.highlights.length > 0 && (
                <p class="text-sm font-normal text-text-body-secondary leading-relaxed">
                  {exp.highlights.join(". ") + "."}
                </p>
              )}
              <p class="text-xs font-normal text-text-body-tertiary mt-1">
                {exp.duration}
              </p>
            </div>
          ))
        }
      </section>

      <Divider />

      {/* ⭐ SECTION 3: TOOLKIT (Compétences) */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary text-center">
          My toolkit for impact
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-xl">
          <div class="space-y-md">
            <h3
              class="text-lg font-bold text-text-body-primary flex items-center gap-2"
            >
              Hard skills
            </h3>
            <ul class="space-y-2 text-text-body-primary">
              {
                toolkit.hardSkills.map((skill) => (
                  <li class="p-3 bg-gray-50 rounded-lg">
                    <p class="font-semibold text-sm">{skill.title}</p>
                    {skill.description && (
                      <p class="mt-1 text-xs text-text-body-secondary">
                        {skill.description}
                      </p>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="space-y-md">
            <h3
              class="text-lg font-bold text-text-body-primary flex items-center gap-2"
            >
              Soft Skills
            </h3>
            <ul class="space-y-2 text-text-body-primary">
              {
                toolkit.softSkills.map((skill) => (
                  <li class="p-3 bg-gray-50 rounded-lg">
                    <p class="font-semibold text-sm">{skill.title}</p>
                    {skill.description && (
                      <p class="mt-1 text-xs text-text-body-secondary">
                        {skill.description}
                      </p>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="space-y-md">
            <h3
              class="text-lg font-bold text-text-body-primary flex items-center gap-2"
            >
              Interests
            </h3>
            <ul class="space-y-2 text-text-body-primary">
              {
                toolkit.personalInterests.map((interest) => (
                  <li class="p-3 bg-gray-50 rounded-lg">
                    <p class="font-semibold text-sm">{interest.title}</p>
                    {interest.description && (
                      <p class="mt-1 text-xs text-text-body-secondary">
                        {interest.description}
                      </p>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <Divider />

      {/* ⭐ SECTION 4: SIGNIFICANT WORK (NOUVEAU) */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">
          Significant Work
        </h2>

        {
          significantWork.map((project) => (
            // Utilise une structure simplifiée similaire à l'expérience
            <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start">
                <h3 class="text-base font-semibold text-text-body-primary">
                  {project.title}
                </h3>
              </div>
              <p class="text-sm font-normal text-text-body-secondary leading-relaxed mt-2">
                {project.description}
              </p>
            </div>
          ))
        }
      </section>

      <Divider />

      {/* ⭐ SECTION 5: FORMATION (Structure mise à jour) */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">
          Education & Background
        </h2>
        {
          educationExperience.map((edu) => (
            <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start">
                <h3 class="text-base font-semibold text-text-body-primary">
                  {edu.title}
                </h3>
              </div>
              {/* School (agit comme 'company' dans la structure) */}
              <p class="text-sm font-normal text-text-body-primary mb-md">
                {edu.school}
              </p>
              {/* Year/Duration (agit comme 'duration' dans la structure) */}
              <p class="text-xs font-normal text-text-body-tertiary mt-1">
                {edu.year}
              </p>
            </div>
          ))
        }
      </section>
    </Container>
  </main>
</BaseLayout>
