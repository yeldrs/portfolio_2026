---
// Importez vos Layout et composants
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Divider from "../components/Divider.astro";
import Button from "../components/Button.astro"; // Pour le bouton Contact

// Vos données pour la page
const profileImageUrl = "/images/profile-pic.jpg"; // ASSUREZ-VOUS QUE CE CHEMIN EST CORRECT

// ✅ CORRECTION TS: Définir le type du tableau pour rendre 'highlights' optionnel
const professionalExperience: Array<{ 
    title: string; 
    company: string; 
    duration: string;
    highlights?: string[]; 
}> = [
 {
  title: "UX Product Designer",
  company: "900.care - D2C Startup",
  duration: "Paris, Sept. 2024 - Sept. 2025",
  // highlights: est commenté (correctement géré ci-dessous)
 /* highlights: [
   "Collaborated closely with the PM and dev team to optimize user journeys for conversion, retention, and product discovery.",
   "Increased Average Basket Value by +47% through the design and A/B testing of cross-sell modals and a funnel redesign.",
   "Contributed to stabilizing the 4-week retention rate above 70% by designing a new order management space and optimizing the churn flow.",
   "Spearheaded the entire Diagnosis Phase (Quantitative research on 400 clients, 27 qualitative interviews, moderated tests) and developed a Design System aligned with developer needs.",
  ],*/
 },
 {
  title: "Independent Designer & Web Consultant",
  company: "Freelance",
  duration: "Paris, 2023 - 2024",
  // highlights: est commenté
  /*highlights: [
   "Provided consulting on visual identity conception for various clients, including Maison Le Roux.",
   "Delivered services in digital strategy and Search Engine Optimization (SEO).",
  ],*/
 },
 {
  title: "Art Director",
  company: "Maison Le Roux (Agri-Food Sector)",
  duration: "Paris, Mar. - Sept. 2022",
  // highlights: est commenté
  /*highlights: [
   "Contributed to brand strategy development alongside the marketing department.",
   "Developed creative concepts for digital and print communication materials.",
   "Managed the visual identity application across Paris retail boutiques and designed the point-de-vente stand for the Salon du Chocolat.",
  ],*/
 },
];

const toolkit = {
 hardSkills: [
  "End-to-End Design: From research (quali/quanti) to final design delivery.",
  "Figma (Expert): High-fidelity prototyping, advanced Design System management and maintenance.",
  "Data & Analytics: Reading and analyzing behavioral data (Metabase, Clarity, NPS, A/B testing).",
 ],
 softSkills: [
  "Data-Driven Rigor: Justifying design choices with metrics (A/B tests, KPIs).",
  "Agile & Autonomy: Mastery of Scrum rituals and the ability to autonomously lead the Discovery process.",
  "Influence & Communication: Ability to align design with technical constraints (HTML/CSS) and business goals (OKR).",
 ],
 interests: [
  "GreenTech & Responsible Design: Linking modern tools to fundamental environmental and societal needs.",
  "Health & Well-being: Interest in accessibility and designing positive, well-being-focused experiences.",
  "Emerging Technologies: Pragmatic use of AI (Gemini, ChatGPT) and automation (N8N, Make) for efficiency gains.",
 ],
};
---

<BaseLayout title="À Propos de Yassine El Idrissi - Product Designer">
 <main>
  <Container class="pt-xl pb-3xl px-lg flex flex-col gap-3xl md:gap-4xl">
   
      <section class="flex flex-col md:flex-row md:items-start gap-lg md:gap-xl max-w-5xl mx-auto">
    
    <div class="flex-shrink-0 w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden self-center md:self-auto">
     <img 
      src={profileImageUrl} 
      alt="Yassine El Idrissi - Profile Picture" 
      class="w-full h-full object-cover" 
     />
    </div>

    <div class="space-y-md flex-1">
     <h1 class="text-4xl font-extrabold text-text-body-primary">Hello, I'm Yassine 👋</h1>
     <p class="text-xl font-normal text-text-body-primary">
      I’m a **Product Designer** who loves translating user insights into genuine experiences that are measurable, valuable, and most importantly... **built for people.**
     </p>
     <p class="text-base text-text-body-secondary leading-relaxed">
      As a Product Designer, my mission goes beyond pixel perfection: **I position myself at the intersection of user research, data, and business performance.** Avec une expérience solide dans un environnement D2C exigeant (startup 900.care), j'excelle à transformer un diagnostic utilisateur précis en solutions concrètes qui améliorent la conversion, augmentent la rétention et maximisent la valeur client.
     </p>
     <p class="text-base text-text-body-secondary leading-relaxed">
      Je conçois des produits utiles et accessibles, en m'assurant que chaque décision de design sert de levier de croissance, toujours conscient de l'impact sociétal et environnemental de la technologie.
     </p>
     <Button href="/contact" class="mt-lg">Let's Connect</Button>
    </div>
   </section>

   <Divider />
      
      <section class="max-w-6xl mx-auto w-full space-y-xl">
          <h2 class="text-3xl font-bold text-text-body-primary text-center">The Toolkit for Impact</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-xl">
              
              <div class="space-y-md">
                  <h3 class="text-xl font-bold text-text-body-primary flex items-center gap-2">🛠️ Hard Skills (Tech & Tools)</h3>
                  <ul class="space-y-2 text-base text-text-body-primary">
                    {toolkit.hardSkills.map((skill) => (
                      <li class="p-3 bg-gray-50 rounded-lg">{skill}</li>
                    ))}
                  </ul>
              </div>
              
              <div class="space-y-md">
                  <h3 class="text-xl font-bold text-text-body-primary flex items-center gap-2">💬 Soft Skills (Behavior & Process)</h3>
                  <ul class="space-y-2 text-base text-text-body-primary">
                    {toolkit.softSkills.map((skill) => (
                      <li class="p-3 bg-gray-50 rounded-lg">{skill}</li>
                    ))}
                  </ul>
              </div>
              
              <div class="space-y-md">
                  <h3 class="text-xl font-bold text-text-body-primary flex items-center gap-2">🧠 Key Interests & Values</h3>
                  <ul class="space-y-2 text-base text-text-body-primary">
                    {toolkit.interests.map((interest) => (
                      <li class="p-3 bg-gray-50 rounded-lg">{interest}</li>
                    ))}
                  </ul>
              </div>
              
          </div>
      </section>
  
   <Divider />

         <section class="max-w-5xl mx-auto w-full space-y-xl">
    <h2 class="text-3xl font-bold text-text-body-primary">Professional Experience Highlights</h2>

    {professionalExperience.map((exp) => (
     <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
      <div class="flex flex-col md:flex-row md:justify-between md:items-start">
       <h3 class="text-lg font-semibold text-text-body-primary">{exp.title}</h3>
       <span class="text-sm font-medium text-text-body-tertiary md:text-right">{exp.duration}</span>
      </div>
      <p class="text-base font-normal text-text-body-secondary mb-md">{exp.company}</p>
      
            {exp.highlights && exp.highlights.length > 0 && (
                <ul class="list-disc ml-6 space-y-2 text-base text-text-body-primary">
                    {exp.highlights.map((highlight) => (
                        <li>{highlight}</li>
                    ))}
                </ul>
            )}
            
     </div>
    ))}
   </section>

   <Divider />
   
        <section class="max-w-5xl mx-auto w-full text-center space-y-md">
    <h2 class="text-3xl font-extrabold text-text-body-primary uppercase">Yassine El Idrissi</h2>
    <p class="text-lg font-normal text-text-body-secondary">Product Designer • Paris</p>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-md pt-md">
     <a href="https://linkedin.com/in/yassineelidrissi" target="_blank" class="text-sm font-medium text-background-brand hover:underline">
      LinkedIn
     </a>
     <span class="hidden sm:block text-text-body-tertiary">|</span>
     <a href="mailto:yass.elidrissi97@gmail.com" class="text-sm font-medium text-background-brand hover:underline">
      yass.elidrissi97@gmail.com
     </a>
    </div>
   </section>
  

  </Container>
 </main>
</BaseLayout>