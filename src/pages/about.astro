---
// Importez vos Layout et composants
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
//import Divider from "../components/Divider.astro";
import Button from "../components/Button.astro"; // Pour le bouton Contact

// Vos données pour la page
const profileImageUrl = "/images/profile-pic.webp"; // ASSUREZ-VOUS QUE CE CHEMIN EST CORRECT

// ✅ Données du CV : EXPÉRIENCES PROFESSIONNELLES (Rédaction anglaise mise à jour)
const professionalExperience: Array<{
  title: string;
  company: string;
  duration: string;
  highlights?: string[];
}> = [
  {
    title: "UX Product Designer",
    company: "900.care - D2C Startup",
    duration: "Sept. 2024 - Sept. 2025 (Paris)",
    highlights: [
      "End-to-End role in an Agile team to maximize conversion, retention, and product discovery.",
    ],
  },
  {
    title: "Web Designer",
    company: "Freelance",
    duration: "2023 - 2024 (Remote)",
    highlights: [
      "Consulting services in digital strategy, Search Engine Optimization (SEO), WordPress and WebFlow.",
    ],
  },
  {
    title: "Art Director",
    company: "Freelance",
    duration: "June. 2022 - Jan. 2023 (Paris)",
    highlights: [
      "Supported clients, including Maison Le Roux, on visual identity conception and brand strategy.",
    ],
  },
  {
    title: "Art Director",
    company: "Maison Le Roux - Food Industry",
    duration: "Mar. 2021 - Jul. 2022 (Paris)",
    highlights: [
      "Led brand strategy across digital and retail channels, ensuring consistency across all customer touchpoints.",
    ],
  },
];

// ✅ Données du CV : TOOLKIT (Structure 3.b: Réorganisation des compétences en 3 groupes professionnels)
const toolkit: {
  coreDesign: { title: string; description: string }[];
  methodology: { title: string; description: string }[];
  modernImperatives: { title: string; description: string }[];
  personalInterests: { title: string; description: string }[];
} = {
  coreDesign: [
    {
      title: "End-to-end design",
      description:
        "From research (qualitative/quantitative) to final design delivery.",
    },
    {
      title: "Figma / Loveable / Framer",
      description:
        "High-fidelity prototyping, advanced Design System management.",
    },
    {
      title: "Adobe Suite / Affinity",
      description: "Photoshop expert, vector design and more.",
    },
    {
      title: "Web coding",
      description:
        "Solid knowledge of HTML/CSS, GitHub, web frameworks, communication with developers.",
    },
  ],
  methodology: [
    {
      title: "Data & UX analytics",
      description:
        "Tracking and analysis of behavioral data (Metabase, Clarity, Datadog, Hotjar).",
    },
    {
      title: "Data-driven design",
      description: "Justifying design choices by metrics (UX testing, ROI).",
    },
    {
      title: "Agile & autonomy",
      description:
        "Mastery of Scrum rituals and capacity to autonomously lead design processes.",
    },
    {
      title: "Communication & collaboration",
      description:
        "Aligning design with technical constraints and business objectives (OKR, KPI).",
    },
  ],
  modernImperatives: [
    {
      title: "Accessibility",
      description:
        "Proficiency in digital accessibility standards (RGAA, WCAG).",
    },
    {
      title: "AI & automation",
      description:
        "LLM assistance (Gemini, ChatGPT, Claude) and automation (N8N, Make).",
    },
    {
      title: "Sustainable & responsible design",
      description: "Linking modern tools to environmental and societal issues.",
    },
    {
      title: "Care-design & health-tech",
      description:
        "Interest in accessibility, food-tech, health-focused problematics.",
    },
  ],
  personalInterests: [
    {
      title: "Sports & Outdoors",
      description:
        "Hiking, climbing, biketouring and really anything nature-oriented !!",
    },
  ],
};

// Définition de la structure de rendu pour les 3 colonnes principales
const skillSections = [
  { title: "Core Design & Tools", skills: toolkit.coreDesign },
  { title: "Methodology & Business", skills: toolkit.methodology },
  { title: "Tech Imperatives", skills: toolkit.modernImperatives },
];

// ✅ NOUVELLE SECTION : Significant Work
const significantWork: Array<{
  title: string;
  description: string;
}> = [
  {
    title: "FoodTech - Batchcooking plateform",
    description:
      "Co-developed the MVP of a digital service that enhances social connection and food autonomy for students.",
  },
  {
    title: "Sustainable agile toolkit - Caisse des Dépôts",
    description:
      "Created a project management tool to develop products that integrate ethics, sustainability, and inclusive principles. Team of 3 designers.",
  },
  {
    title: "Animal Health - Digital Support Service",
    description:
      "Designed and prototyped an app in sync with connected devices to help users care for animals with special needs.",
  },
];

// ✅ Données du CV : FORMATION (Rédaction anglaise mise à jour)
const educationExperience: Array<{
  year: string;
  title: string;
  school: string;
}> = [
  {
    year: "2024-2025",
    title: "Master in Project Management and UX Design",
    school:
      "ISCOD, France (Intensive 12-month program under an apprenticeship contract)",
  },
  {
    year: "2020-2022",
    title: "Master in Digital Design",
    school: "École de Design Nantes Atlantique, France",
  },
  {
    year: "2016-2019",
    title: "Bachelor in Graphic Design",
    school: "Quasar Institute for Advanced Design, Rome, Italy",
  },
];
---

<BaseLayout title="About Yassine El Idrissi - Product Designer">
  <main>
    <Container class="py-3xl px-lg flex flex-col gap-3xl">
      {/* ⭐ SECTION 1: PROFIL & INTRODUCTION */}
      <section
        class="flex flex-col md:flex-row md:items-start gap-lg md:gap-xl max-w-3xl"
      >
        <div class="space-y-lg flex-1">
          <h2 class="text-3xl font-extrabold text-text-body-primary">
            My name is Yassine, Product designer.
          </h2>
          <p class="text-base text-text-body-secondary leading-relaxed">
            I aim at that sweet spot between user research and business
            performance. Turning real user insights into tools that boost
            growth, answer needs , and keep people coming back. I’m learning how
            to build durable ideas.
          </p>
          {
            /*  <p
            class="text-base font-semibold text-text-body-secondary leading-relaxed"
          >
            I design useful, sustainable products while tracking business and
            user insights.
          </p>*/
          }
          <Button href="#contact" class="mt-lg">Let's connect :D</Button>
        </div>
        {
          /* <div
     class="flex-shrink-0 w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden self-center md:self-auto"
    >
     <img
      src={profileImageUrl}
      alt="Yassine El Idrissi - Profile Picture"
      class="w-full h-full object-cover"
     />
    </div>*/
        }
      </section>

      {/* ⭐ SECTION 2: EXPÉRIENCES PROFESSIONNELLES */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">Experience</h2>
        {
          professionalExperience.map((exp) => (
            <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start">
                <h3 class="text-base font-semibold text-text-body-primary">
                  {exp.title}
                </h3>
              </div>
              <p class="text-sm font-normal text-text-body-primary mb-md">
                {exp.company}
              </p>
              {/* Affichage des highlights en un seul paragraphe (Description) */}
              {exp.highlights && exp.highlights.length > 0 && (
                <p class="text-sm font-normal text-text-body-secondary leading-relaxed">
                  {exp.highlights.join(". ") + "."}
                </p>
              )}
              <p class="text-xs font-normal text-text-body-tertiary mt-1">
                {exp.duration}
              </p>
            </div>
          ))
        }
      </section>

      {/* ⭐ SECTION 3: TOOLKIT (Compétences - Structure 3.b) */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">
          My toolkit for impact
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-xl">
          {/* Colonne 1: Core Design & Tools */}
          <div class="space-y-md">
            <h3
              class="text-lg font-bold text-text-body-primary flex items-center gap-2"
            >
              {skillSections[0].title}
            </h3>
            <ul class="space-y-2 text-text-body-primary">
              {
                skillSections[0].skills.map((skill) => (
                  <li class="p-3 bg-gray-50 rounded-lg">
                    <p class="font-semibold text-sm">{skill.title}</p>
                    {skill.description && (
                      <p class="mt-1 text-xs text-text-body-secondary">
                        {skill.description}
                      </p>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>

          {/* Colonne 2: Methodology & Business */}
          <div class="space-y-md">
            <h3
              class="text-lg font-bold text-text-body-primary flex items-center gap-2"
            >
              {skillSections[1].title}
            </h3>
            <ul class="space-y-2 text-text-body-primary">
              {
                skillSections[1].skills.map((skill) => (
                  <li class="p-3 bg-gray-50 rounded-lg">
                    <p class="font-semibold text-sm">{skill.title}</p>
                    {skill.description && (
                      <p class="mt-1 text-xs text-text-body-secondary">
                        {skill.description}
                      </p>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>

          {
            /* Colonne 3: Modern Imperatives & Tech (remplace 'Interests' pour les compétences pro) */
          }
          <div class="space-y-md">
            <h3
              class="text-lg font-bold text-text-body-primary flex items-center gap-2"
            >
              {skillSections[2].title}
            </h3>
            <ul class="space-y-2 text-text-body-primary">
              {
                skillSections[2].skills.map((skill) => (
                  <li class="p-3 bg-gray-50 rounded-lg">
                    <p class="font-semibold text-sm">{skill.title}</p>
                    {skill.description && (
                      <p class="mt-1 text-xs text-text-body-secondary">
                        {skill.description}
                      </p>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        {
          /* Intérêts Personnels (déplacé sous la grille de compétences pro) 
        {
          toolkit.personalInterests.length > 0 && (
            <div class="space-y-md pt-xl border-t border-stroke-secondary">
              <h3 class="text-lg font-bold text-text-body-primary">
                Personal Interests
              </h3>
              <div class="flex flex-wrap gap-md">
                {toolkit.personalInterests.map((interest) => (
                  <span class="px-3 py-1 bg-gray-50 rounded-full text-sm font-medium text-text-body-primary">
                    {interest.title}
                  </span>
                ))}
              </div>
            </div>
          )
        }*/
        }
      </section>

      {/* ⭐ SECTION 4: SIGNIFICANT WORK (NOUVEAU) */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">
          Significant Work
        </h2>

        {
          significantWork.map((project) => (
            // Utilise une structure simplifiée similaire à l'expérience
            <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start">
                <h3 class="text-base font-semibold text-text-body-primary">
                  {project.title}
                </h3>
              </div>
              <p class="text-sm font-normal text-text-body-secondary leading-relaxed mt-2">
                {project.description}
              </p>
            </div>
          ))
        }
      </section>

      {/* ⭐ SECTION 5: FORMATION (Structure mise à jour) */}
      <section class="w-full max-w-3xl space-y-xl">
        <h2 class="text-3xl font-bold text-text-body-primary">Education</h2>
        {
          educationExperience.map((edu) => (
            <div class="space-y-sm pb-lg border-b border-stroke-secondary last:border-b-0">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start">
                <h3 class="text-base font-semibold text-text-body-primary">
                  {edu.title}
                </h3>
              </div>
              {/* School (agit comme 'company' dans la structure) */}
              <p class="text-sm font-normal text-text-body-primary mb-md">
                {edu.school}
              </p>
              {/* Year/Duration (agit comme 'duration' dans la structure) */}
              <p class="text-xs font-normal text-text-body-tertiary mt-1">
                {edu.year}
              </p>
            </div>
          ))
        }
      </section>
    </Container>
  </main>
</BaseLayout>
