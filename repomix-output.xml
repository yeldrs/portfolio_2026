// 1. Importez le Layout de base
import BaseLayout from "../layouts/BaseLayout.astro";

// 2. Importez les composants nécessaires
import ProjectCard from "../components/ProjectCard.astro";
import Container from "../components/Container.astro";
import Hero from "../components/Hero.astro";
import Divider from "../components/Divider.astro";
import { getCollection } from "astro:content";

// use a neutral placeholder instead (plus fiable)
const PlaceholderImage = "/images/profile-pic.webp"; // Doit pointer vers /public

// 🔴 RÉCUPÉRATION DYNAMIQUE DES DONNÉES DE LA COLLECTION 'projects'
const allProjects = (
  await getCollection("projects", ({ data }) => {
    // Filtre les brouillons
    return data.isDraft !== true;
  })
).sort((a, b) => {
  // Triez par date de publication (plus récent en premier)
  const dateA = new Date(a.data.publishDate).getTime();
  const dateB = new Date(b.data.publishDate).getTime();
  return dateB - dateA;
});
---

<BaseLayout title="Yassine El Idrissi -  UX Design">
  <main>
    <Container class="px-lg pb-5xl flex flex-col gap-5xl md:gap-3xl">
      <section
        class="h-[68vh] flex flex-col justify-center items-center space-y-4xl md:p-5xl"
      >
        <Hero
          title="Hello, I'm Yassine 👋"
          subtitle="I’m a product designer who translates user insights into genuine experiences that are measurable, valuable, and more importantly... built for people. "
          profileImage={PlaceholderImage}
        />

        <div class="flex flex-col items-center gap-xl">
          {
            (
              <a
                href="#projects"
                class="text-sm font-normal text-text-body-accent"
              >
                Case studies
              </a>
            )
          }

          <div class="text-stroke-primary-dark animate-bounce">
            <a href="#projects" aria-label="Scroll down to projects">
              <svg
                width="19"
                height="39"
                viewBox="0 0 19 39"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="h-10 w-6"
              >
                <path
                  d="M10.455 1.25C10.455 0.559644 9.89531 3.01764e-08 9.20496 0C8.5146 -3.01764e-08 7.95496 0.559644 7.95496 1.25L9.20496 1.25L10.455 1.25ZM8.32107 38.1339C8.80923 38.622 9.60068 38.622 10.0888 38.1339L18.0438 30.1789C18.5319 29.6908 18.5319 28.8993 18.0438 28.4112C17.5556 27.923 16.7642 27.923 16.276 28.4112L9.20495 35.4822L2.13389 28.4112C1.64573 27.923 0.854275 27.923 0.36612 28.4112C-0.122035 28.8993 -0.122035 29.6908 0.36612 30.1789L8.32107 38.1339ZM9.20496 1.25L7.95496 1.25L7.95495 37.25L9.20495 37.25L10.455 37.25L10.455 1.25L9.20496 1.25Z"
                  fill="currentColor"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <section
        id="projects"
        role="region"
        aria-label="Projects"
        class="flex flex-col space-y-6xl"
      >
        {
          allProjects.map((project, index) => (
            <>
              <ProjectCard
                id={project.slug}
                headline={project.data.title}
                client={project.data.client}
                description={project.data.description}
                role={project.data.role}
                projectLink={`/work/${project.data.semanticSlug}`}
                imageAlt={`Aperçu du projet ${project.data.title}`}
                imageUrl={project.data.cardImage}
                direction={index % 2 === 0 ? "reverse" : "default"}
              />
            </>
          ))
        }
      </section>
    </Container>
  </main>
</BaseLayout>
