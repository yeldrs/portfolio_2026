---
import Button from "./Button.astro";

export interface Props {
  headline: string;
  client: string;
  description?: string;
  role: string;
  projectLink: string;
  imageAlt: string;
  imageUrl: string;
  direction?: "default" | "reverse";
  id?: string;
}

const {
  headline,
  client,
  description,
  role,
  projectLink,
  imageAlt,
  imageUrl,
  direction = "default",
  id,
} = Astro.props;

// --- LOGIQUE DE TRACKING MUTUALISÉE ---

// Format pour Simple Analytics (snake_case : view_project_900_care)
const projectSlugSA = client
  .toLowerCase()
  .replace(/\s+/g, "_")
  .replace(/[^\w_]/g, "");
const eventNameSA = `view_project_${projectSlugSA}`;

// Format pour Umami (kebab-case : 900-care)
const projectSlugUmami = client
  .toLowerCase()
  .replace(/\s+/g, "-")
  .replace(/[^\w-]/g, "");

const directionClass = direction === "reverse" ? "md:flex-row-reverse" : "";
---

<article
  id={id ?? undefined}
  role="article"
  aria-label={headline}
  class={`flex flex-col md:flex-row gap-xl md:gap-3xl bg-background-primary ${directionClass} md:items-start`}
>
  <h1
    class="text-4xl font-extrabold text-text-body-primary md:hidden m-0"
    set:html={headline}
  />

  <a
    href={projectLink}
    data-sa-event={eventNameSA}
    data-umami-event="project-image-click"
    data-umami-event-project={projectSlugUmami}
    aria-label={`Voir le projet : ${headline}`}
    class="block group flex-1 md:basis-1/2 relative rounded-2xl aspect-[4/3] order-2 md:order-none overflow-hidden"
