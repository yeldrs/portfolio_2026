      <div>
        <span class="block text-base font-normal text-text-body-tertiary mb-xxs"
          >Client</span
        >
        <p class="text-base font-normal text-text-body-primary">
          {client}
        </p>
      </div>

      <div>
        <span class="block text-base font-normal text-text-body-tertiary mb-xxs"
          >Description</span
        >
        <p class="text-base font-normal text-text-body-primary leading-normal">
          {description}
        </p>
      </div>

      <div>
        <span class="block text-base font-normal text-text-body-tertiary mb-xxs"
          >Role</span
        >
        <p class="text-base font-normal text-text-body-primary">
          {role}
        </p>
      </div>
    </div>
    <div>
      <Button
        href={projectLink}
        data-sa-event={eventNameSA}
        data-umami-event="project-button-click"
        data-umami-event-project={projectSlugUmami}
      >
        View project
      </Button>
    </div>
  </section>
</article>
