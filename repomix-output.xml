import Container from "./Container.astro";
import CopyIcon from "./CopyIcon.astro";

interface SocialLink {
  name: string;
  href: string;
  icon: string;
  trackingId: string;
}

const socialLinks: SocialLink[] = [
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/yassineelidrissi/", // Remplacez par votre lien réel
    icon: "M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z",
    trackingId: "linkedin",
  },
];

const currentYear = new Date().getFullYear();
const emailAddress = "contact@yassineelidrissi.com";

const copyToClipboard = `(function(e) {
const email = "${emailAddress}";
const clickedElement = e.currentTarget; 

// Tracking Manuel pour Simple Analytics & Umami lors du clic
if (window.sa_event) sa_event("footer_email_copy");
if (window.umami) umami.track("footer-email-copy");

if (window.isSecureContext === false && window.location.protocol !== 'http:') {
   console.error("Clipboard access restricted.");
   return;
 }

navigator.clipboard.writeText(email).then(() => {
 const message = "Email copied!";
 let existingToast = document.getElementById('copy-toast');
 if (existingToast) existingToast.remove();

 const rect = clickedElement.getBoundingClientRect();
 const toast = document.createElement('div');
 toast.id = 'copy-toast';
 toast.textContent = message;

 toast.style.cssText = \`
  position: fixed;
  left: \${rect.left + rect.width / 2}px;
  top: \${rect.bottom + 10}px; 
  transform: translateX(-50%); 
  background-color: black;
  color: white;
  padding: 0.5rem 1rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 600;
  z-index: 50;
  opacity: 0;
  transition: opacity 0.3s, transform 0.3s;
 \`;

 document.body.appendChild(toast);
 setTimeout(() => {
  toast.style.opacity = '1';
  toast.style.transform = 'translateX(-50%) translateY(0)'; 
 }, 10);

 setTimeout(() => {
  toast.style.opacity = '0';
  toast.style.transform = 'translateX(-50%) translateY(-10px)'; 
  setTimeout(() => toast.remove(), 300);
 }, 2500);
}).catch(err => {
 console.error("Failed to copy email: ", err);
});
}).call(this, event)`;
---

