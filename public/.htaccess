# public/.htaccess

RewriteEngine On
RewriteBase /

# --- GESTION DU TRAILING SLASH (RETRAIT DU / FINAL) ---
# Si ce n'est pas un dossier réel
RewriteCond %{REQUEST_FILENAME} !-d
# Et que l'URL se termine par un slash
RewriteCond %{REQUEST_URI} ^/(.+)/$
# On redirige vers la version sans slash
RewriteRule ^(.+)/$ /$1 [R=301,L]

# --- GESTION DE LA PAGE 404 ---
ErrorDocument 404 /404.html

# Rediriger le dossier parent vide vers la section dédiée de l'accueil
Redirect 301 /work /#projects
Redirect 301 /work/ /#projects

# --- VOS REDIRECTIONS EXISTANTES ---
Redirect 301 /projects /#projects
Redirect 301 /aboutme /about
Redirect 301 /logos /
Redirect 301 /photography /

# --- FORCER LE HTTPS ---
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- URLs PROPRES (MASQUER .HTML) ---
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]